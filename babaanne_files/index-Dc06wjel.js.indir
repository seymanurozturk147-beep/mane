w-10 min-w-10 text-xl"}}}),m7=({size:e})=>{const{userIsLoggedIn:a,userVisibleName:o,getInitial:i,userAvatarUrl:l}=ct();return a?M.jsx("div",{className:gd({size:e}),children:l?M.jsx(mm,{imageUrl:l,name:o,size:e||Ra.md}):i()}):M.jsx("div",{className:gd({size:e})})},Tq="/static/example-user-avatar.png",_0e=({size:e})=>M.jsx("div",{className:gd({size:e}),children:M.jsx(mm,{imageUrl:Tq,name:"Example User",size:e||Ra.md})}),Iq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google se bepalings</a> en <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">beleid oor gebruik</a> geld. Die <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">privaatheidkennisgewing</a> beskryf hoe jou data hanteer word. Jou gesprekke en kode kan nagegaan word en gebruik word om Google KI te verbeter. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Kry meer inligting oor jou keuses</a>. Stitch kan foute maak. Dubbelkontroleer dit dus en <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">gebruik kode versigtig</a>.</p>',privacyHeader:"Stitch-privaatheidkennisgewing",privacyBody:'<p>Laas opgedateer: 20 Mei 2025</p><p>Hierdie kennisgewing en ons <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privaatheidsbeleid</a> beskryf hoe Stitch jou data hanteer. Lees dit asseblief aandagtig deur.</p><p>Wanneer jy Stitch gebruik, samel Google jou gesprekke (insluitend porboodskappe en aanhegsels, en gegenereerde uitsette), verwante kenmerke se gebruikinligting, en jou terugvoer in. Google gebruik hierdie data ooreenkomstig ons <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privaatheidsbeleid</a>, onder meer om Google-produkte en -dienste en masjienleertegnologie te verskaf, te verbeter en te ontwikkel. Mense wat kontrolerings uitvoer (insluitend opgeleide kontroleerders van ons diensverskaffers af), gaan sommige gesprekke vir hierdie doeleindes na. Moet asseblief nie vertroulike inligting invoer wat jy nie wil hê ’n kontroleerder moet sien of Google moet gebruik om Google KI te verbeter nie.</p><p>As jy nie wil hê jou toekomstige gesprekke moet gebruik word om ons generatiewe KI-modelle op te lei nie, kan jy in jou Stitch<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">-instellings</a> onttrek. As jy kies om terugvoer te verskaf, kan Google dié terugvoer en enige geassosieerde inhoud (bv. verwante gesprekke) gebruik om ons generatiewe KI-modelle op te lei, selfs al het jy onttrek.</p>',settingsHeader:"Laat KI-modelopleiding toe",settingsBody:'<p>Laat Google toe om jou toekomstige Stitch-gesprekke te gebruik om hul generatiewe KI-modelle op te lei. As jy onttrek, geld dit nie vir enige terugvoer wat jy dalk kies om te verskaf nie. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Meer inligting</a>.</p>'},Hq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">የGoogle ደንቦች</a> እና <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">የአጠቃቀም መመሪያ</a> ይተገበራል። <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">የግላዊነት ማስታወቂያ</a> ውሂብዎ እንዴት እንደሚያዝ ይገልጻል። የእርስዎ ውይይቶች እና ኮድ ሊገመገሙ እና Google ሰው ሠራሽ አስተውሎትን ለማሻሻል ጥቅም ላይ ሊውሉ ይችላሉ። <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ስለ ምርጫዎችዎ ይወቁ</a>. Stitch ስሕተቶችን ሊሠራ ይችላል፣ ስለዚህ በድጋሚ ያረጋግጡት እና <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">በጥንቃቄ ኮድ ይጠቀሙ </a>።</p>',privacyHeader:"Stitch የግላዊነት ማስታወቂያ",privacyBody:'<p>ለመጨረሻ ጊዜ የዘመነው፦ ሜይ 20፣ 2025</p><p>ይህ ማስታወቂያ እና የእኛ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">የግላዊነት መመሪያ</a> Stitch የእርስዎን ውሂብ እንዴት እንደሚይዝ ይገልጻሉ። እባክዎ በጥንቃቄ ያንብቧቸው።</p><p>Stitch በሚጠቀሙበት ጊዜ Google የእርስዎን ውይይቶች (ጥያቄዎችን እና ዓባሪዎችን እና የመነጨ ውፅዓትን ጨምሮ)፣ ተዛማጅ የአጠቃቀም መረጃን እና ግብረመልስዎን ይሰበስባል። Google የGoogle ምርቶች እና አገልግሎቶችን እና በማሽን መማር ቴክኖሎጂዎችን ለማቅረብ፣ ለማሻሻል እና ለማሳደግ ጨምሮ ይህን ውሂብ ከእኛ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">የግላዊነት መመሪያ</a> ጋር ወጥ በሆነ መልኩ ይጠቀማል። የሰው ገምጋሚዎች (ከግልጋሎት ሰጪዎቻችን የሠለጠኑ ገምጋሚዎችን ጨምሮ) ለእነዚህ ዓላማዎች አንዳንድ ውይይቶችን ይገመግማሉ። እባክዎ ገምጋሚ እንዲያየው ወይም Google የGoogle ሰው ሠራሽ አስተውሎትን ለማሻሻል እንዲጠቀምበት የማይፈልጉትን ሚስጥራዊ መረጃ አያስገቡ።</p><p>የወደፊት ውይይቶችዎ የእኛን ሰው ሠራሽ አስተውሎት አመንጪ ሞዴሎችን ለማሠልጠን ጥቅም ላይ እንዲውሉ ካልፈለጉ፣ ከእርስዎ Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ቅንብሮች</a> ውስጥ መርጠው መውጣት ይችላሉ። ግብረመልስ ለመስጠት ከመረጡ፣ መርጠው ቢወጡም እንኳ Google ያንን ግብረመልስ እና ማንኛውንም ተዛማጅ ይዘት (ለምሳሌ፣ ተዛማጅ ውይይቶች) በመጠቀም የእኛን አመንጪ AI ሞዴሎችን ለማሰልጠን ይችላል።</p>',settingsHeader:"የሰው ሠራሽ አስተውሎት ሞዴል ሥልጠናን ይፍቀዱ",settingsBody:'<p>ሰው ሠራሽ አስተውሎት አመንጪ ሞዴሎቹን ለማሠልጠን Google የእርስዎን የወደፊት የStitch ውይይቶችን እንዲጠቀም ይፍቀዱ። መርጦ መውጣት እርስዎ ለማቅረብ ሊመርጡት ለሚችሉት ማንኛውም ግብረመልስ አይተገበርም። <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">የበለጠ ለመረዳት</a>።</p>'},Vq={banner:'<p>تسري <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">بنود</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">خدمة</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google</a> و<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">سياسة</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">الاستخدام</a>. ويوضّح <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">إشعار</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">الخصوصية</a> كيفية التعامل مع بياناتك. قد تتم مراجعة محادثاتك ورموزك البرمجية واستخدامها في تحسين ذكاء Google الاصطناعي. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">إليك</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">معلومات</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">عن</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">الخيارات</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">المتاحة</a>. قد يرتكب Stitch أخطاء، لذا يُنصح بالتحقّق من ردوده و<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">استخدام</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">الرموز</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">البرمجية</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">بحذر</a>.</p>',privacyHeader:"إشعار خصوصية Stitch",privacyBody:'<p>تاريخ آخر تعديل: 20 مايو 2025</p><p>يوضِّح هذا الإشعار و<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">سياسة</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">الخصوصية</a> الطريقة التي يعالج بها Stitch بياناتك. يُرجى قراءتهما بعناية.</p><p>عند استخدام Stitch، تجمع Google محادثاتك (بما فيها الطلبات والمرفقات والنتائج المولَّدة) ومعلومات عن استخدام الميزات المرتبطة وملاحظاتك. وتستخدم Google هذه البيانات، بما يتوافق مع <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">سياسة</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">الخصوصية</a> المتّبعة لديها، لتوفير وتحسين وتطوير منتجات Google وخدماتها وتكنولوجيات تعلُّم الآلة. ويفحص المراجعون (بما في ذلك المراجعون المدرّبون من مقدّمي الخدمات المعتمدين لدينا) بعض هذه المحادثات لهذه الأغراض. يُرجى عدم إدخال معلومات سرية في حال عدم موافقتك على اطّلاع المراجعين عليها أو استخدام Google لها من أجل تحسين ذكاء Google الاصطناعي.</p><p>في حال عدم موافقتك على أن يتم استخدام محادثاتك المستقبلية في تدريب نماذج الذكاء الاصطناعي التوليدي لدينا، يمكنك إيقاف مشاركة البيانات من خلال <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">إعدادات</a> Stitch. وإذا اخترت إرسال ملاحظاتك، يمكن أن تستخدمها Google، بالإضافة إلى أي محتوى مرتبط بها (مثل المحادثات ذات الصلة)، بهدف تدريب نماذج الذكاء الاصطناعي التوليدي لدينا، حتى لو أوقفت خيار المشاركة.</p>',settingsHeader:"السماح بتدريب نموذج الذكاء الاصطناعي",settingsBody:'<p>يمكنك منح Google الإذن باستخدام محادثاتك المستقبلية في Stitch لتدريب نماذج الذكاء الاصطناعي التوليدي الخاصة بها. يُرجى العِلم أنّ إيقاف مشاركة هذه البيانات لا يسري على أي ملاحظات يتم تقديمها من جانبك. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">مزيد</a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">من</a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">المعلومات</a></p>'},Lq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googleৰ চৰ্তাৱলী</a> আৰু <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ব্যৱহাৰৰ নীতি</a> প্ৰযোজ্য। <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তাৰ জাননী</a>য়ে আপোনাৰ ডেটা কিদৰে পৰিচালনা কৰা হয় সেয়া বৰ্ণনা কৰে। আপোনাৰ বাৰ্তালাপ আৰু ক’ডসমূহ পৰ্যালোচনা কৰা হ’ব পাৰে আৰু সেয়া Google AI উন্নত কৰিবলৈ ব্যৱহাৰ কৰা হ’ব পাৰে। <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">আপোনাৰ পচন্দসমূহৰ বিষয়ে জানক</a>। Stitchএ ভুল কৰিব পাৰে, সেয়ে এয়া পুনৰ পৰীক্ষা কৰক আৰু <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ক’ড সাৱধানে ব্যৱহাৰ কৰক</a>।</p>',privacyHeader:"Stitchৰ গোপনীয়তাৰ জাননী",privacyBody:'<p>অন্তিমবাৰ আপডে’ট কৰাৰ সময়: ২০ মে’, ২০২৫</p><p>এই জাননী আৰু আমাৰ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তাৰ নীতি</a>য়ে আপোনাৰ ডেটা Stitchএ কেনেকৈ পৰিচালনা কৰে সেয়া বৰ্ণনা কৰে। অনুগ্ৰহ কৰি সেইসমূহ গুৰুত্ব সহকাৰে পঢ়ক।</p><p>আপুনি Stitch ব্যৱহাৰ কৰোঁতে, Googleএ আপোনাৰ বাৰ্তালাপসমূহ (প্ৰ’ম্পট্‌ আৰু সংলগ্নক আৰু সৃষ্ট আউটপুটকে ধৰি), সম্পৰ্কিত সুবিধা ব্যৱহাৰৰ তথ্য আৰু আপোনাৰ মতামত সংগ্ৰহ কৰে। Googleএ এই ডেটা আমাৰ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তাৰ নীতি</a>ৰ সৈতে সামঞ্জস্যপূৰ্ণভাৱে, Googleৰ প্ৰ’ডাক্ট আৰু সেৱাসমূহ আৰু মেচিন লাৰ্নিং প্ৰযুক্তিসমূহ প্ৰদান, উন্নত আৰু বিকাশ কৰাকে ধৰি কাৰ্যসমূহ কৰিবলৈ ব্যৱহাৰ কৰে। মানৱ পৰ্যালোচকসকলে (আমাৰ সেৱা প্ৰদানকাৰীৰ প্ৰশিক্ষিত পর্যালোচককে ধৰি) এই উদ্দেশ্যসমূহৰ বাবে কিছুমান বাৰ্তালাপ পৰ্যালোচনা কৰে। অনুগ্ৰহ কৰি আপুনি কোনো পৰ্যালোচকক চাবলৈ দিব নিবিচৰা বা Google AI উন্নত কৰিবৰ বাবে Googleক ব্যৱহাৰ কৰিবলৈ দিব নিবিচৰা গোপনীয় তথ্য নিদিব।</p><p>যদি আপুনি আপোনাৰ ভৱিষ্যতৰ বাৰ্তালাপসমূহ আমাৰ Generative AI মডেলক প্ৰশিক্ষণ দিবলৈ ব্যৱহাৰ কৰাটো নিবিচাৰে, আপুনি আপোনাৰ Stitchৰ<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ছেটিঙ</a>ত অপ্ট-আউট কৰিব পাৰে। আপুনি মতামত দিবলৈ বাছনি কৰিলে, Googleএ সেই মতামত আৰু যিকোনো জড়িত সমল (যেনে, সম্পৰ্কিত বাৰ্তালাপ) আমাৰ Generative AI মডেলসমূহক প্ৰশিক্ষণ দিবলৈ ব্যৱহাৰ কৰিব পাৰে, আনকি আপুনি অপ্ট আউট কৰিলেও।</p>',settingsHeader:"AI মডেলসমূহক প্ৰশিক্ষণ দিবলৈ দিয়ক",settingsBody:'<p>Googleক ইয়াৰ Generative AI মডেলসমূহক প্ৰশিক্ষণ দিবৰ বাবে আপোনাৰ ভৱিষ্যতৰ Stitchৰ বাৰ্তালাপ ব্যৱহাৰ কৰিবলৈ দিয়ক। আপুনি দিবলৈ বাছনি কৰা যিকোনো মতামতৰ ক্ষেত্ৰত অপ্ট আউট কৰাটো প্ৰযোজ্য নহয়। <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">অধিক জানক</a>।</p>'},Oq={banner:'<p>Прилагат се <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Условията на Google</a> и <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">правилата относно използването</a>. В <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Съобщението за поверителност</a> е описано как се обработват данните ви. Вашите разговори и код може да бъдат преглеждани и да се използват за подобряване на AI на Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Научете повече за опциите за избор</a>. Stitch може да допуска грешки, затова проверявайте повторно и <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">използвайте кода внимателно</a>.</p>',privacyHeader:"Съобщение за поверителност за Stitch",privacyBody:'<p>Последна актуализация: 20 май 2025 г.</p><p>В настоящото съобщение и в <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Декларацията ни за поверителност</a> е описано как Stitch обработва данните ви. Моля, прочетете ги внимателно.</p><p>Когато използвате Stitch, Google събира вашите разговори (включително подканите, прикачените файлове и генерираните изходни резултати), информация за използването на сродни функции и отзивите ви. Използваме тези данни в съответствие с <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Декларацията си за поверителност</a>, включително с цел предоставяне, подобряване и разработване на нашите продукти и услуги и технологиите ни за машинно обучение. За тези цели проверяващи лица (включително обучени проверяващи лица от доставчиците ни на услуги) преглеждат някои разговори. Не въвеждайте поверителна информация, която не бихте искали да е видима за проверяващи лица или да се използва от нас за подобряване на AI на Google.</p><p>Ако не искате бъдещите ви разговори да се използват за обучение на моделите ни на генеративен AI, можете да се откажете от това в <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">настройките</a> на Stitch. В случай че изпратите отзиви, Google може да ги използва, както и свързаното с тях съдържание (например свързаните разговори), за да обучава моделите си на AI дори ако сте се отказали.</p>',settingsHeader:"Разрешаване на обучението на моделите на AI",settingsBody:'<p>Разрешете на Google да използва бъдещите ви разговори в Stitch с цел обучение на моделите си на генеративен AI. Отказът не се отнася за отзивите, които изпратите. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Научете повече</a>.</p>'},Zq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google-এর শর্তাবলী</a> এবং <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ব্যবহার সংক্রান্ত নীতি</a> প্রযোজ্য। আপনার ডেটা কীভাবে ম্যানেজ করা হয় তা <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তা বিজ্ঞপ্তি</a> থেকে জানতে পারবেন। Google AI উন্নত করার জন্য আপনার কথোপকথন ও কোড পর্যালোচনা এবং ব্যবহার করা হতে পারে। <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">আপনার পছন্দ সম্পর্কে জানুন</a>। Stitch ভুল করতে পারে, তাই ডবল-চেক করুন এবং <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">কোড ব্যবহার করার সময় সাবধানতা অবলম্বন করুন</a>।</p>',privacyHeader:"Stitch-এর গোপনীয়তা বিজ্ঞপ্তি",privacyBody:'<p>শেষবার আপডেট করা হয়েছে: ২০ মে, ২০২৫</p><p>Stitch কীভাবে আপনার ডেটা ম্যানেজ করে তা আমাদের <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তা নীতিতে</a> বর্ণনা করা হয়েছে। এগুলি মন দিয়ে পড়ুন।</p><p>আপনি Stitch ব্যবহার করলে, Google আপনার কথোপকথন (যার মধ্যে আছে প্রম্পট, অ্যাটাচমেন্ট এবং জেনারেট করা আউটপুট), সম্পর্কিত ফিচার ব্যবহারের তথ্য এবং আপনার মতামত সংগ্রহ করে। Google আমাদের <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">গোপনীয়তা নীতি</a> অনুযায়ী এই ডেটা ব্যবহার করে, যার মধ্যে Google প্রোডাক্ট, পরিষেবা ও মেশিন লার্নিং প্রযুক্তি প্রদান, উন্নত এবং তৈরি করা অন্তর্ভুক্ত। হিউম্যান রিভিউয়ার (আমাদের পরিষেবা প্রদানকারী টিমের ট্রেনিংপ্রাপ্ত রিভিউয়াররাও এর মধ্যে রয়েছেন) এইসব উদ্দেশ্যে কিছু কথোপকথন পর্যালোচনা করেন। আপনার যেসব গোপনীয় তথ্য রিভিউয়ারদের দেখাতে বা Google-কে তার Google AI উন্নত করার জন্য ব্যবহার করতে দিতে চান না, সেগুলি লিখবেন না।</p><p>আমাদের জেনারেটিভ AI মডেলের ট্রেনিংয়ের জন্য আপনার ভবিষ্যতের কথোপকথন জমা দিতে না চাইলে, Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">সেটিংসে</a> গিয়ে এটি বন্ধ করতে পারেন। আপনি মতামত জমা দিলে Google সেই মতামত ও সম্পর্কিত যেকোনও তথ্য (যেমন, সংশ্লিষ্ট কথোপকথন) আমাদের জেনারেটিভ AI মডেলকে ট্রেনিং দিতে ব্যবহার করবে এবং আপনি ভবিষ্যতে তথ্য শেয়ার বন্ধ করার পরেও এই তথ্য ব্যবহার চালিয়ে যাবে।</p>',settingsHeader:"AI মডেল ট্রেনিংয়ে ব্যবহারের অনুমতি দিন",settingsBody:'<p>Google-এর জেনারেটিভ AI মডেল ট্রেনিংয়ের জন্য, Stitch-এ আপনার ভবিষ্যতের কথোপকথন ব্যবহার করার অনুমতি দিন। আপনি তথ্য শেয়ারের সেটিংস বন্ধ করলেও যেসব মতামত জমা দেবেন সেগুলির তথ্য ব্যবহার করা হবে। <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">আরও জানুন</a>।</p>'},wq={banner:`<p>S'hi apliquen les <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">condicions de Google</a> i la <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">política d'usos</a>. L'<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">avís de privadesa</a> descriu com es gestionen les teves dades. Les teves converses i el teu codi es podrien revisar i utilitzar per millorar la IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Obtén informació sobre les teves opcions</a>. Stitch pot cometre errors, així que comprova'n els resultats i <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">utilitza el codi amb precaució</a>.</p>`,privacyHeader:"Avís de privadesa de Stitch",privacyBody:`<p>Darrera actualització: 20 de maig de 2025</p><p>Aquest avís i la nostra <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">política de privadesa</a> descriuen com gestiona Stitch les teves dades. Llegeix-los atentament.</p><p>Quan fas servir Stitch, Google recull les converses (inclosos els fitxers adjunts, les indicacions i les sortides generades), la informació relacionada d'ús de la funció i els teus suggeriments. Google utilitza aquestes dades d'acord amb la nostra <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">política de privadesa</a> per, entre d'altres, proporcionar, millorar i desenvolupar productes i serveis de Google i tecnologies d'aprenentatge automàtic. Amb aquestes finalitats, revisors humans (com ara els revisors qualificats dels nostres proveïdors de serveis) revisen algunes converses. No introdueixis informació confidencial que no vulguis que un revisor vegi o que Google utilitzi per millorar la IA de Google.</p><p>Si no vols que les teves converses futures s'utilitzin per entrenar els nostres models d'IA generativa, pots desactivar-ho a la <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">configuració</a> de Stitch. Si decideixes proporcionar suggeriments, Google els pot fer servir juntament amb tot el contingut associat (p. ex., les converses relacionades) per entrenar els nostres models d'IA generativa encara que hagis desactivat l'opció.</p>`,settingsHeader:"Permet l'entrenament dels models d'IA",settingsBody:`<p>Permet que Google utilitzi les teves converses futures amb Stitch per entrenar els seus models d'IA generativa. La desactivació d'aquesta opció no s'aplica als suggeriments que decideixis proporcionar. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Obtén més informació</a>.</p>`},Cq={banner:'<p>Platí <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">smluvní podmínky společnosti Google</a> a <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">zásady užívání</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Upozornění ve věci ochrany soukromí</a> popisuje, jak zpracováváme vaše data. Vaše konverzace a kód mohou být zkontrolovány a využity k vylepšování Google AI. Přečtěte si <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">další informace o tom, jaké máte možnosti volby</a>. Stitch může dělat chyby, takže si všechno kontrolujte a <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">kód používejte s rozvahou</a>.</p>',privacyHeader:"Upozornění ve věci ochrany soukromí ve službě Stitch",privacyBody:'<p>Naposledy aktualizováno: 20. května 2025</p><p>Toto oznámení a naše <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">zásady ochrany soukromí</a> popisují, jak služba Stitch nakládá s vašimi daty. Pozorně si je přečtěte.</p><p>Když používáte službu Stitch, shromažďuje společnost Google vaše konverzace (včetně pokynů a příloh a vygenerovaného výstupu), související informace o používání funkcí a vaši zpětnou vazbu. Společnost Google tato data používá v souladu se svými <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">zásadami ochrany soukromí</a>, mimo jiné také k poskytování, zlepšování a vývoji produktů a služeb Google a technologií strojového učení. Za tímto účelem některé konverzace kontrolují lidé (včetně vyškolených kontrolorů od našich poskytovatelů služeb). Nezadávejte důvěrné informace, u kterých nechcete, aby je viděl kontrolor nebo aby je společnost Google používala k vylepšování své umělé inteligence.</p><p>Z používání budoucích konverzací k trénování modelů generativní umělé inteligence se můžete v <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">nastavení</a> služby Stitch odhlásit. Pokud poskytnete zpětnou vazbu, může ji a přidružený obsah (např. související konverzace) společnost Google použít k trénování svých modelů generativní umělé inteligence i v případě, že jste se odhlásili.</p>',settingsHeader:"Povolit trénování modelů umělé inteligence",settingsBody:'<p>Nechat Google používat budoucí konverzace se službou Stitch k trénování modelů generativní umělé inteligence. Odhlášení se nevztahuje na případnou vámi poskytnutou zpětnou vazbu. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Další informace</a></p>'},Gq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googles servicevilkår</a> samt <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Anvendelsespolitik</a> er gældende. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Privatlivsmeddelelsen</a> beskriver, hvordan dine data håndteres. Dine samtaler og din kode kan blive gennemgået og brugt til at forbedre Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Lær om dine valgmuligheder </a>. Stitch kan lave fejl, så tjek det grundigt og <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">brug kode med forsigtighed </a>.</p>',privacyHeader:"Privatlivsmeddelelse for Stitch",privacyBody:'<p>Senest opdateret: 20. maj 2025</p><p>Denne meddelelse og vores <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privatlivspolitik</a> beskriver, hvordan Stitch håndterer dine data. Læs dem omhyggeligt.</p><p>Når du bruger Stitch, indsamler Google dine samtaler (herunder prompter og vedhæftede filer samt genereret output), relateret information om funktionsbrug og din feedback. Google bruger disse data i overensstemmelse med vores <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privatlivspolitik</a>, herunder til at levere, forbedre og udvikle Googles produkter og tjenester samt teknologier til maskinlæring. Menneskelige kontrollanter (herunder oplærte kontrollanter fra vores tjenesteudbydere) gennemgår nogle samtaler med disse formål for øje. Indtast ikke fortrolige oplysninger, som du ikke ønsker, at en kontrollant skal se, eller at Google skal bruge til at forbedre Google AI.</p><p>Hvis du ikke ønsker, at dine fremtidige samtaler bruges til at træne vores generativ AI-modeller, kan du fravælge dette i dine <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">indstillinger</a> for Stitch. Hvis du vælger at give feedback, kan Google bruge denne feedback og alt tilknyttet indhold (f.eks. relaterede samtaler) til at træne vores generativ AI-modeller, selvom du har fravalgt dette.</p>',settingsHeader:"Tillad AI-modeltræning",settingsBody:'<p>Lad Google bruge dine fremtidige Stitch-samtaler til at træne sine generativ AI-modeller. Fravalg gælder ikke for feedback, du selv måtte vælge at give. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Få flere oplysninger</a>.</p>'},xq={banner:'<p>Es gelten die <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google-Nutzungsbedingungen</a> und die <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Richtlinie zur unzulässigen Nutzung von generativer KI</a>. In den <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Datenschutzhinweisen</a> wird die Verwendung Ihrer Daten beschrieben. Ihre Unterhaltungen und Ihr Code werden möglicherweise von Prüfern angesehen und können zur Verbesserung von Google AI verwendet werden. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Hier erfahren Sie mehr über Ihre Auswahlmöglichkeiten</a>. Stitch kann Fehler machen, überprüfen Sie daher die Antworten und <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">verwenden Sie den Code mit Vorsicht</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Letzte Aktualisierung: 20. Mai 2025</p><p>In diesen Hinweisen und unserer <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a> wird erläutert, wie Stitch mit Ihren Daten umgeht. Bitte lesen Sie die Informationen sorgfältig durch.</p><p>Wenn Sie Stitch verwenden, erfasst Google Ihre Unterhaltungen (einschließlich Prompts und Anhängen sowie der generierten Ausgabe), Informationen zur Nutzung zugehöriger Funktionen und Ihr Feedback. Diese Daten werden gemäß unserer <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a> verwendet, um unter anderem Google-Produkte und ‑Dienste sowie Technologien für maschinelles Lernen bereitzustellen, zu verbessern und weiterzuentwickeln. Zu diesen Zwecken werden einige Unterhaltungen von Prüfern (einschließlich Prüfern unserer Dienstleister) überprüft. Bitte geben Sie daher keine vertraulichen Informationen an, die nicht von Prüfern angesehen oder von Google zur Verbesserung von Google AI verwendet werden sollen.</p><p>Wenn Sie nicht möchten, dass Ihre zukünftigen Unterhaltungen zum Trainieren unserer generativen KI-Modelle verwendet werden, können Sie in den <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Stitch-Einstellungen</a> die entsprechende Option deaktivieren. Wenn Sie Feedback geben, kann Google dieses Feedback und die zugehörigen Inhalte, z. B. zugehörige Unterhaltungen, zum Trainieren unserer generativen KI-Modelle verwenden. Dies gilt auch, wenn Sie die Option deaktiviert haben.</p>',settingsHeader:"Trainieren von KI-Modellen erlauben",settingsBody:'<p>Sie können Google erlauben, zukünftige Unterhaltungen in Stitch zum Trainieren seiner generativen KI-Modelle zu verwenden. Feedback, das Sie geben, kann immer zu diesem Zweck verwendet werden – auch wenn die Option deaktiviert ist. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Weitere Informationen</a></p>'},Nq={banner:'<p>Ισχύουν οι <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Όροι</a> και η <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Πολιτική χρήσης</a> της Google. Η <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Σημείωση απορρήτου</a> περιγράφει τον τρόπο διαχείρισης των δεδομένων σας. Οι συνομιλίες και ο κώδικάς σας ενδέχεται να ελεγχθούν και να χρησιμοποιηθούν για τη βελτίωση του Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Μάθετε σχετικά με τις επιλογές σας</a>. Το Stitch μπορεί να κάνει λάθη, επομένως θα πρέπει να επαληθεύετε τις απαντήσεις του και <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">να χρησιμοποιείτε τον κώδικα με προσοχή</a>.</p>',privacyHeader:"Σημείωση απορρήτου για το Stitch",privacyBody:'<p>Τελευταία ενημέρωση: 20 Μαΐου 2025</p><p>Η παρούσα σημείωση και η <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Πολιτική απορρήτου</a> μας περιγράφουν τον τρόπο με τον οποίο το Stitch χειρίζεται τα δεδομένα σας. Διαβάστε τες προσεκτικά.</p><p>Όταν χρησιμοποιείτε το Stitch, η Google συλλέγει τις συνομιλίες σας (συμπεριλαμβανομένων των οδηγιών, των συνημμένων και των αποτελεσμάτων εξόδου που δημιουργούνται), σχετικές πληροφορίες για τη χρήση λειτουργιών, καθώς και τα σχόλιά σας. Η Google χρησιμοποιεί αυτά τα δεδομένα σύμφωνα με την <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Πολιτική απορρήτου</a> της, μεταξύ άλλων, για την παροχή, τη βελτίωση και την ανάπτυξη προϊόντων και υπηρεσιών Google και τεχνολογιών μηχανικής μάθησης. Οι αναθεωρητές (συμπεριλαμβανομένων εκπαιδευμένων αναθεωρητών από παρόχους υπηρεσιών με τους οποίους συνεργαζόμαστε) ελέγχουν ορισμένες συνομιλίες για τους παραπάνω σκοπούς. Μην εισάγετε εμπιστευτικές πληροφορίες που δεν θέλετε να δουν οι αναθεωρητές ή να χρησιμοποιήσει η Google για τη βελτίωση του Google AI.</p><p>Αν δεν θέλετε να χρησιμοποιηθούν οι μελλοντικές σας συνομιλίες για την εκπαίδευση των generative μοντέλων AI της Google, μπορείτε να εξαιρεθείτε από τις <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ρυθμίσεις</a> του Stitch. Αν επιλέξετε να παράσχετε σχόλια, η Google μπορεί να χρησιμοποιήσει τα εν λόγω σχόλια και τυχόν σχετικό περιεχόμενο (π.χ. σχετικές συνομιλίες) για την εκπαίδευση των generative μοντέλων AI, ακόμα κι αν έχετε εξαιρεθεί.</p>',settingsHeader:"Να επιτρέπεται η εκπαίδευση μοντέλων AI",settingsBody:'<p>Επιτρέψτε στην Google να χρησιμοποιεί μελλοντικές συνομιλίες από το Stitch για την εκπαίδευση των generative μοντέλων AI. Η εξαίρεση από την εν λόγω χρήση δεν καλύπτει τυχόν σχόλια που επιλέγετε να παράσχετε. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Μάθετε περισσότερα</a>.</p>'},Rq={banner:'<p>Se aplican los <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Términos de Google</a> y la <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Política de Usos</a>. En el <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Aviso de Privacidad</a> se describe cómo se tratan tus datos. Las conversaciones y el código se pueden revisar y usar para mejorar la IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Consulta información sobre tus opciones</a>. Stitch puede cometer errores, así que comprueba sus respuestas y <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">usa el código con precaución</a>.</p>',privacyHeader:"Aviso de Privacidad de Stitch",privacyBody:'<p>Última actualización: 20 de mayo del 2025</p><p>En este aviso y en nuestra <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidad</a> se describe cómo trata Stitch tus datos. Léelos detenidamente.</p><p>Cuando usas Stitch, Google recoge tus conversaciones (incluidos los archivos adjuntos, las peticiones y los resultados generados), la información sobre el uso de las funciones relacionadas y tus comentarios. Google utiliza estos datos de acuerdo con su <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidad</a> para ofrecer, mejorar y desarrollar sus productos y servicios, así como sus tecnologías de aprendizaje automático, entre otros. Algunas conversaciones las examinan revisores humanos (incluidos revisores especializados de nuestros proveedores de servicios) para esos fines. No incluyas información confidencial que no quieras que vean los revisores o que no quieras que Google use para mejorar la IA de Google.</p><p>Si no quieres que se usen tus futuras conversaciones para entrenar nuestros modelos de IA generativa, puedes inhabilitar la opción en los <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ajustes</a> de Stitch. Si decides enviar tus comentarios, Google puede usarlos junto con el contenido asociado (por ejemplo, las conversaciones relacionadas) para entrenar nuestros modelos de IA generativa aunque hayas inhabilitado la opción.</p>',settingsHeader:"Permitir el entrenamiento de modelos de IA",settingsBody:'<p>Permite que Google use tus futuras conversaciones de Stitch para entrenar sus modelos de IA generativa. Aunque inhabilites la opción, se seguirán usando los comentarios que decidas enviarnos. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Más información</a></p>'},Dq={banner:`<p>Kehtivad <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google'i tingimused</a> ja <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">kasutusreeglid</a>. Teie teabe töötlemist kirjeldatakse <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">privaatsusteatises</a>. Teie vestlusi ja koodi võidakse üle vaadata ning kasutada Google'i AI täiustamiseks. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Vaadake teavet oma valikute kohta</a>. Stitch võib eksida, nii et kontrollige selle vastused üle ja <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">olge koodi kasutamisel ettevaatlik</a>.</p>`,privacyHeader:"Stitchi privaatsusteatis",privacyBody:`<p>Viimati värskendatud: 20. mail 2025</p><p>See teatis ja meie <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privaatsuseeskirjad</a> kirjeldavad, kuidas Stitch teie andmeid käsitleb. Lugege neid hoolikalt.</p><p>Kui Stitchi kasutate, kogub Google teie vestlusi (sh päringuid, manuseid ja genereeritud väljundit), seotud funktsioonide kasutusteavet ja teie tagasisidet. Google kasutab neid andmeid kooskõlas meie <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privaatsuseeskirjadega</a>, muu hulgas Google'i toodete ja teenuste ning masinõppetehnoloogiate pakkumiseks, täiustamiseks ja arendamiseks. Ülevaatajad (sh meie teenusepakkujate koolitatud ülevaatajad) vaatavad mõned vestlused nendel eesmärkidel üle. Ärge sisestage konfidentsiaalset teavet, mida te ei soovi, et ülevaataja näeks või Google oma AI täiustamiseks kasutaks.</p><p>Kui te ei soovi, et teie tulevasi vestlusi kasutatakse meie generatiivse AI mudelite treenimiseks, saate sellest loobuda Stitchi <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">seadetes</a>. Kui otsustate tagasisidet anda, saab Google seda tagasisidet ja kogu seotud sisu (nt seotud vestlusi) kasutada meie generatiivse AI mudelite treenimiseks, isegi kui olete sellest loobunud.</p>`,settingsHeader:"AI-mudeli treenimise lubamine",settingsBody:`<p>Lubage Google'il kasutada teie tulevasi Stitchi vestlusi Google'i generatiivse AI mudelite treenimiseks. Loobumine ei kehti tagasiside puhul, mida võite esitada. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Vaadake lisateavet</a>.</p>`},kq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google-ren Baldintzak</a> eta <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Erabilera-gidalerroak</a> aplikatzen dira. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Pribatutasun-oharrak</a> azaltzen du datuak nola kudeatzen diren. Baliteke elkarrizketak eta kodea berrikustea eta Google-ren AA hobetzeko erabiltzea. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Lortu zure aukerei buruzko informazioa</a>. Baliteke Stitch-ek akatsak egitea. Beraz, egiazta ezazu eta <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">erabili kodea kontu handiz</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Azken eguneratze-data: 2025eko maiatzaren 20a</p><p>Stitch-ek zure datuak nola kudeatzen dituen azaltzen da ohar honetan eta gure <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Pribatutasun-gidalerroetan</a>. Irakur itzazu arretaz.</p><p>Stitch erabiltzen duzunean, Google-k zure elkarrizketak (eskaera-mezuak, eranskinak eta sortutako emaitzak barne), eginbide-erabilerari buruzko informazioa eta zure oharrak biltzen ditu. Google-ren produktuak, zerbitzuak eta ikasketa automatikoko teknologiak eskaintzeko, hobetzeko eta garatzeko erabiliko ditu Google-k datu horiek, Google-ren <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Pribatutasun-gidalerroetan</a> ezarritakoari jarraikiz. Gizakiak diren berrikusleek (gure zerbitzu-hornitzaileen berrikusle trebatuak barne) elkarrizketa batzuk berrikusten dituzte xede horietarako. Ez idatzi isilpeko informaziorik berrikusle batek ikustea edo Google-k produktuak, zerbitzuak eta ikasketa automatikoko tresnak hobetzeko erabiltzea nahi ez baduzu.</p><p>Etorkizuneko elkarrizketak AAko eredu generatiboak trebatzeko erabiltzea nahi ez baduzu, aukeratu eginbide hori ez erabiltzea Stitch-en <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ezarpenetan</a>. Oharrak bidaltzea erabakitzen baduzu, Google-k AAko eredu generatiboak trebatzeko erabili ahalko ditu ohar horiek eta erlazionatutako edukia (adibidez, erlazionatutako elkarrizketak), eginbidea ez erabiltzea aukeratu baduzu ere.</p>',settingsHeader:"Eman AAko ereduak trebatzeko baimena",settingsBody:'<p>Eman Stitch-eko etorkizuneko elkarrizketak erabiltzeko baimena Google-ri, AAko eredu generatiboak trebatzeko. Ez erabiltzea aukeratzen baduzu ere, bidaltzen dituzun oharrak erabili ahalko dira. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Lortu informazio gehiago</a>.</p>'},Pq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">شرایط</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">خدمات</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google</a> و <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">خط</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">‌</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">مشی</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">استفاده</a> اعمال می‌شود. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">اعلامیه</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">حریم</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">خصوصی</a> نحوه استفاده از داده‌هایتان را شرح می‌دهد. مکالمه‌ها و کد شما ممکن است برای بهبود هوش مصنوعی Google بازبینی و استفاده شود. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">درباره</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">انتخاب</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">‌</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">هایتان</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">بیشتر</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">بدانید</a>. ‫Stitch ممکن است اشتباه کند، بنابراین آن را دوباره‌سنجی کنید و <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">از</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کد</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">بااحتیاط</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">استفاده</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کنید</a>.</p>',privacyHeader:"اعلامیه حریم خصوصی Stitch",privacyBody:'<p>آخرین به‌روزرسانی: ۲۰ مه ۲۰۲۵</p><p>این اعلامیه و <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">خط</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">‌</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">مشی</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">رازداری</a> ما نحوه مدیریت داده‌هایتان توسط Stitch را توضیح می‌دهند. لطفاً آن‌ها را به‌دقت مطالعه کنید.</p><p>وقتی از Stitch استفاده می‌کنید، Google مکالمه‌های شما (ازجمله پیام‌واره‌ها و پیوست‌ها، و بروندادهای تولیدشده)، اطلاعات استفاده ویژگی مربوط، و بازخورد شما را جمع‌آوری می‌کند. ‫Google مطابق با <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">خط</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">‌</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">مشی</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">رازداری</a> ما از این داده‌ها استفاده می‌کند، ازجمله برای ارائه، بهبود، و توسعه محصولات و سرویس‌ها و فناوری‌های یادگیری ماشین Google. افراد بازبین (شامل بازبین‌های آموزش‌دیده از رسانندگان خدمات ما) برخی‌از مکالمه‌ها را برای این اهداف بازبینی می‌کنند. لطفاً اطلاعات محرمانه‌ای را که نمی‌خواهید افراد بازبین ببینند یا Google برای بهبود هوش مصنوعی Google استفاده کند وارد نکنید.</p><p>اگر نمی‌خواهید از مکالمه‌های آتی شما برای آموزش مدل‌های هوش مصنوعی زایای ما استفاده شود، می‌توانید در <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">تنظیمات</a> Stitch انصراف دهید. اگر بازخورد ارائه دهید، حتی وقتی انصراف داده باشید Google می‌تواند از این بازخورد و هرگونه محتوای منسوب (برای نمونه، مکالمه‌های مرتبط) برای آموزش مدل‌های هوش مصنوعی زایای ما استفاده کند.</p>',settingsHeader:"مجاز کردن آموزش مدل هوش مصنوعی",settingsBody:'<p>به Google اجازه داده می‌شود از مکالمه‌های آتی شما با Stitch برای آموزش مدل‌های هوش مصنوعی زایای خود استفاده کند. انصراف دادن شامل بازخوردهایی که ممکن است ارائه دهید نمی‌شود. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">بیشتر</a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">بدانید</a>.</p>'},zq={banner:'<p>Nalalapat ang <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Mga Tuntunin ng Google</a> at <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Patakaran sa Paggamit</a>. Inilalarawan ng <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Notification ng Privacy</a> kung paano pinapangasiwaan ang data mo. Posibleng suriin at gamitin ang iyong mga pag-uusap at code para mapahusay ang Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Alamin ang tungkol sa iyong mga pagpipilian</a>. Posibleng magkamali ang Stitch, kaya i-double check ito at <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">gamitin ang code nang may pag-iingat</a>.</p>',privacyHeader:"Notification ng Privacy ng Stitch",privacyBody:'<p>Huling na-update noong: Mayo 20, 2025</p><p>Inilalarawan ng abisong ito at ng aming <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Patakaran sa Privacy</a> kung paano pinapangasiwaan ng Stitch ang iyong data. Pakibasa nang mabuti ang mga ito.</p><p>Kapag ginamit mo ang Stitch, kinokolekta ng Google ang iyong mga pag-uusap (kasama na ang mga prompt at attachment at binuong output), impormasyon sa paggamit ng kaugnay na feature, at feedback mo. Ginagamit ng Google ang data na ito nang naaayon sa aming <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Patakaran sa Privacy</a>, kasama na ang layuning ibigay, pahusayin, at i-develop ang mga produkto at serbisyo ng Google at mga teknolohiya sa machine learning. Sinusuri ng taong tagasuri (kasama na ang mga sinanay na reviewer mula sa mga service provider namin) ang ilang pag-uusap para sa mga layuning ito. Huwag maglagay ng kumpidensyal na impormasyong ayaw mong makita ng tagasuri o magamit ng Google sa pagpapahusay ng Google AI.</p><p>Kung ayaw mong gamitin ang mga pag-uusap mo sa hinaharap para sanayin ang mga generative AI model namin, puwede kang mag-opt out sa iyong <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">mga setting</a> sa Stitch. Kung pipiliin mong magbigay ng feedback, puwedeng gamitin ng Google ang feedback na iyon at anumang kaugnay na content (hal., mga kaugnay na pag-uusap) para sanayin ang aming mga generative AI model kahit na nag-opt out ka.</p>',settingsHeader:"Payagan ang Pagsasanay ng AI Model",settingsBody:'<p>Payagan ang Google na gamitin ang mga pag-uusap mo sa Stitch sa hinaharap para sanayin ang mga generative AI model nito. Kapag nag-opt out ka, hindi ito malalapat sa anumang feedback na posibleng piliin mong ibigay. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Matuto pa</a>.</p>'},Uq={banner:`<p>Les <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Conditions d'utilisation de Google</a> et le <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Règlement sur l'utilisation</a> s'appliquent. L'<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Avis de confidentialité</a> explique comment vos données sont traitées. Vos conversations et votre code peuvent être examinés et utilisés pour améliorer l'IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Découvrez les options qui s'offrent à vous.</a> Stitch peut faire des erreurs, vérifiez ses réponses et <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">utilisez son code avec précaution</a>.</p>`,privacyHeader:"Stitch Privacy Notice",privacyBody:`<p>Dernière mise à jour : 20 mai 2025</p><p>Cet avis et nos <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Règles de confidentialité</a> expliquent comment Stitch traite vos données. Nous vous invitons à les lire attentivement.</p><p>Lorsque vous utilisez Stitch, Google collecte vos conversations (y compris vos requêtes et pièces jointes, et la sortie générée), les informations liées à l'utilisation de la fonctionnalité et vos commentaires. Google utilise ces données conformément à ses <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Règles de confidentialité</a>, y compris pour fournir, améliorer et développer ses produits et services, ainsi que ses technologies de machine learning. Des réviseurs humains (y compris des réviseurs spécialisés de nos fournisseurs de services) examineront certaines conversations à ces fins. Veuillez ne pas saisir d'informations confidentielles que vous ne souhaiteriez pas qu'un réviseur consulte ou que Google utilise pour améliorer l'IA de Google.</p><p>Si vous ne souhaitez pas que vos futures conversations soient utilisées pour entraîner nos modèles d'IA générative, vous pouvez le refuser dans les <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">paramètres</a> de Stitch. Si vous choisissez de fournir des commentaires, Google peut les utiliser ainsi que tout contenu associé (comme les conversations associées) afin d'entraîner ses modèles d'IA générative, en dépit de votre refus.</p>`,settingsHeader:"Autoriser l'entraînement de modèles d'IA",settingsBody:`<p>Autoriser Google à utiliser vos futures conversations avec Stitch afin d'entraîner ses modèles d'IA générative. Votre refus ne s'applique pas aux éventuels commentaires que vous pourriez choisir d'envoyer. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">En savoir plus</a></p>`},_q={banner:`<p>Tá feidhm ag <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Téarmaí Google</a> agus ag an <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Polasaí Úsáidte</a>. Déantar cur síos san <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Fhógra Príobháideachais</a> ar an gcaoi a láimhseáiltear do shonraí. D'fhéadfadh do chomhráite agus do chód a athbhreithniú agus iad a úsáid chun IS Google a fheabhsú. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Faigh amach faoi do roghanna</a>. Is féidir le Stitch botúin a dhéanamh, mar sin seiceáil faoi dhó é agus <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">bí faichilleach le cód</a>.</p>`,privacyHeader:"Fógra Príobháideachais Stitch",privacyBody:`<p>An nuashonrú is déanaí: 20 Bealtaine 2025</p><p>Déantar cur síos san fhógra seo agus inár <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">bPolasaí Príobháideachais</a> ar an gcaoi a láimhseáiltear do chuid sonraí in Stitch. Léigh go cúramach iad.</p><p>Nuair a úsáideann tú Stitch, bailíonn Google do chomhráite (lena n-áirítear leideanna agus ceangaltáin agus aschur ginte), faisnéis ghaolmhar faoi úsáid gné, agus d'aiseolas. Úsáideann Google na sonraí sin i gcomhréir lenár <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">bPolasaí Príobháideachais</a>, lena n-áirítear chun táirgí agus seirbhísí Google agus teicneolaíochtaí meaisínfhoghlama a sholáthar, a fheabhsú agus a fhorbairt. Athbhreithníonn athbhreithneoirí daonna (lena n-áirítear athbhreithneoirí oilte ónár soláthraithe seirbhíse) roinnt comhráite chun na gcríoch sin. Ná cuir isteach faisnéis faoi rún nár mhaith leat go bhfeicfeadh athbhreithneoir í ná go n-úsáidfeadh Google í chun IS Google a fheabhsú.</p><p>Mura dteastaíonn uait go n-úsáidfear do chomhráite amach anseo chun ár samhlacha IS giniúnacha a oiliúint, is féidir leat díliostáil i do <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">shocruithe</a> Stitch. Má roghnaíonn tú aiseolas a thabhairt, is féidir le Google an t-aiseolas sin agus aon ábhar gaolmhar (m.sh., comhráite gaolmhara) a úsáid chun ár samhlacha IS giniúnacha a oiliúint fiú má tá tú díliostáilte.</p>`,settingsHeader:"Ceadaigh Oiliúint Samhla IS",settingsBody:`<p>Lig do Google do chomhráite Stitch amach anseo a úsáid chun a shamhlacha IS giniúnacha a oiliúint. Ní bhaineann díliostáil le haon aiseolas a d'fhéadfá a roghnú lena chur ar fáil. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Tuilleadh faisnéise</a>.</p>`},jq={banner:'<p>Aplícanse as <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Condicións de Google</a> e a <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Política de uso</a>. No <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Aviso de privacidade</a> indícase como se tratan os teus datos. As túas conversas e o código poden revisarse e usarse para mellorar a IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Máis información sobre as túas opcións.</a> Stitch pode cometer erros, así que verifica os resultados e <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">usa o código con precaución</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Última actualización: 20 de maio de 2025</p><p>Neste aviso e na nosa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de privacidade</a> indícase como trata Stitch os teus datos. Recomendámosche que leas eses documentos detidamente.</p><p>Cando utilizas Stitch, Google recompila as túas conversas (incluídos as solicitudes, os anexos e os resultados xerados), información relacionada sobre o uso de funcións e os teus comentarios. Google usa estes datos de conformidade coa súa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de privacidade</a> para, entre outras cousas, ofrecer, mellorar e desenvolver os seus produtos, servizos e tecnoloxías de aprendizaxe automática. Para estes fins, contamos cun equipo de revisión (que tamén ten membros dos nosos fornecedores de servizos) que revisa algunhas conversas. Non inclúas información confidencial que non che interese que vexan os membros do equipo de revisión ou que non queiras que use Google para mellorar a súa IA.</p><p>Se non queres que as túas conversas se usen a partir de agora para adestrar os nosos modelos de IA xenerativa, podes desactivar esta opción na <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">configuración</a> de Stitch. Con todo, aínda que o fagas, se decides enviar comentarios, Google poderá utilizalos, así como calquera contido asociado (por exemplo, as conversas relacionadas), para adestrar os seus modelos de IA xenerativa.</p>',settingsHeader:"Permitir adestramento de modelos de IA",settingsBody:'<p>Permite que Google use as conversas que teñas a partir de agora en Stitch para adestrar os seus modelos de IA xenerativa. Aínda que teñas desactivada esta opción, seguiranse utilizando os comentarios que decidas enviar. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Máis información.</a></p>'},Fq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google સેવાની શરતો</a> અને <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ઉપયોગ સંબંધિત પૉલિસી</a> લાગુ થાય છે. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">પ્રાઇવસી નોટિસ</a> તમારા ડેટાને હૅન્ડલ કરવાની રીત વર્ણવે છે. તમારી વાતચીતો અને કોડનો રિવ્યૂ કરવામાં આવી શકે છે અને તેનો ઉપયોગ Google AIને બહેતર બનાવવા માટે થઈ શકે છે. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">તમારી પસંદગીઓ વિશે જાણો</a>. Stitch ભૂલો કરી શકે છે, તેથી બે વાર ચેક કરો અને <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">સાવચેતીથી કોડનો ઉપયોગ કરો</a>.</p>',privacyHeader:"Stitch પ્રાઇવસી નોટિસ",privacyBody:'<p>છેલ્લે અપડેટ કર્યાની તારીખ: 20 મે, 2025</p><p>Stitchની તમારો ડેટા હૅન્ડલ કરવાની રીતનું વર્ણન આ નોટિસ અને અમારી <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">પ્રાઇવસી પૉલિસી</a>માં છે. કૃપા કરીને તેને ધ્યાનપૂર્વક વાંચો.</p><p>જ્યારે તમે Stitchનો ઉપયોગ કરતા હો, ત્યારે Google તમારી વાતચીતો (પ્રૉમ્પ્ટ અને જોડાણો તથા જનરેટ કરેલા આઉટપુટ સહિત), સુવિધાના ઉપયોગ સંબંધિત માહિતી અને તમારો પ્રતિસાદ એકત્ર કરે છે. Googleની પ્રોડક્ટ અને સેવાઓ તથા મશીન લર્નિંગ ટેક્નોલોજી પ્રદાન કરવા સહિત, તેને બહેતર બનાવવા અને ડેવલપ કરવા માટે, Google આ ડેટાનો ઉપયોગ અમારી <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">પ્રાઇવસી પૉલિસી</a> અનુસાર કરે છે. માનવ રિવ્યૂઅર (અમારા સેવા પ્રદાતાઓના પ્રશિક્ષિત રિવ્યૂઅર સહિત) આ હેતુઓ માટે કેટલીક વાતચીતોનો રિવ્યૂ કરે છે. કૃપા કરીને તમે રિવ્યૂઅરને બતાવવા કે Google AIને બહેતર બનાવવા માટે Googleને ઉપયોગ કરવાની મંજૂરી આપવા માગતા ન હો, એવી ગોપનીય માહિતી દાખલ કરશો નહીં.</p><p>જો તમે અમારા જનરેટિવ AI મૉડલને પ્રશિક્ષિત કરવા માટે ભાવિ વાતચીતોનો ઉપયોગ કરવાની મંજૂરી આપવા માગતા ન હો, તો તમે તમારા Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">સેટિંગ</a>માં જઈને નાપસંદ કરી શકો છો. જો તમે પ્રતિસાદ આપવાનું પસંદ કરો, તો Google તે પ્રતિસાદનો અને તેનાથી સંકળાયેલા કોઈપણ કન્ટેન્ટ (દા.ત., સંબંધિત વાતચીતો)નો ઉપયોગ અમારા જનરેટિવ AI મૉડલને પ્રશિક્ષિત કરવા માટે કરી શકે છે, પછી ભલે તમે આ વિકલ્પ નાપસંદ કર્યો હોય.</p>',settingsHeader:"AI મૉડલના પ્રશિક્ષણની મંજૂરી આપો",settingsBody:'<p>Googleને તેના જનરેટિવ AI મૉડલને પ્રશિક્ષિત કરવા માટે Stitchની તમારી ભાવિ વાતચીતોનો ઉપયોગ કરવાની મંજૂરી આપો. તમે આપવાનું પસંદ કર્યા હોય તેવા કોઈપણ પ્રતિસાદ પર નાપસંદ કરવાની ક્રિયા લાગુ થતી નથી. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">વધુ જાણો</a>.</p>'},Bq={banner:'<p>उपयोगकर्ताओं पर <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google की सेवा की शर्तें</a> और <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">इस्तेमाल की नीति</a> लागू होती है. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">निजता नोटिस</a> में बताया गया है कि आपके डेटा का रखरखाव और उसका इस्तेमाल कैसे किया जाता है. Google के एआई को बेहतर बनाने के लिए, आपकी बातचीत के डेटा और कोड की समीक्षा की जा सकती है. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">आपके लिए मौजूद विकल्पों के बारे में जानें</a>. Stitch से गलतियां हो सकती हैं. इसलिए, इससे मिले जवाबों की दोबारा जांच कर लें और <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">कोड का इस्तेमाल सावधानी से करें</a>.</p>',privacyHeader:"Stitch का निजता नोटिस",privacyBody:'<p>पिछले अपडेट की तारीख: 20 मई, 2025</p><p>इस नोटिस और हमारी <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">निजता नीति</a> में बताया गया है कि Stitch आपके डेटा का रखरखाव और उसका इस्तेमाल कैसे करता है. कृपया इन्हें ध्यान से पढ़ें.</p><p>Stitch का इस्तेमाल करने पर, Google आपकी बातचीत का डेटा, इससे जुड़ी सुविधा के इस्तेमाल की जानकारी, और आपके सुझाव, राय या शिकायत से जुड़ा डेटा इकट्ठा करता है. बातचीत के डेटा में, प्रॉम्प्ट, अटैचमेंट, और जनरेट किया गया आउटपुट शामिल है. Google इस डेटा का इस्तेमाल अपनी <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">निजता नीति</a> के मुताबिक करता है. इससे Google के प्रॉडक्ट और सेवाओं को डेवलप करने, उपलब्ध कराने, और उनमें सुधार करने में मदद मिलती है. साथ ही, इसे मशीन लर्निंग टेक्नोलॉजी के लिए भी इस्तेमाल किया जाता है. समीक्षा करने वाले लोग, इन कामों के लिए बातचीत के कुछ हिस्से की समीक्षा करते हैं. इन लोगों में, सेवा देने वाली कंपनियों के समीक्षक भी शामिल हैं. कृपया अपनी बातचीत में ऐसी गोपनीय जानकारी न डालें जो आपको समीक्षा करने वाले लोगों के साथ शेयर नहीं करनी है या जिसका इस्तेमाल करने की अनुमति Google को नहीं देनी है. Google इस जानकारी का इस्तेमाल, Google के एआई को बेहतर बनाने के लिए करता है.</p><p>अगर आपको जनरेटिव एआई मॉडल को ट्रेन करने के लिए, अपनी आगे की बातचीत शेयर नहीं करनी है, तो Stitch की <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">सेटिंग</a> में जाकर, इससे ऑप्ट आउट करें. अगर आपने कोई सुझाव या राय दी है या शिकायत की है, तो आपके ऑप्ट आउट करने पर भी Google इसका या इससे जुड़े कॉन्टेंट (जैसे, इससे जुड़ी बातचीत) का इस्तेमाल अपने जनरेटिव एआई मॉडल को ट्रेन करने के लिए कर सकता है.</p>',settingsHeader:"एआई मॉडल को ट्रेन करने की अनुमति दें",settingsBody:'<p>Google को अपने जनरेटिव एआई मॉडल को ट्रेन करने के लिए, आने वाले समय में Stitch पर होने वाली आपकी बातचीत के डेटा का इस्तेमाल करने की अनुमति दें. ऑप्ट आउट करने पर भी, Google आपके सुझाव, राय या शिकायत का इस्तेमाल कर सकता है. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">ज़्यादा जानें</a>.</p>'},qq={banner:'<p>Primjenjuju se <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googleovi uvjeti</a> i <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Pravila o upotrebi</a>. U <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">obavijesti o privatnosti</a> opisano je na koji se način postupa s vašim podacima. Razgovori i kôd mogu se pregledati i upotrijebiti u svrhu poboljšanja Googleovog AI-ja <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Saznajte više o svojim odabirima</a>. Stitch može pogriješiti, pa provjerite <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">i upotrijebite kôd s oprezom</a>.</p>',privacyHeader:"Obavijest o privatnosti za Stitch",privacyBody:'<p>Posljednje ažuriranje: 20. svibnja 2025.</p><p>U ovoj obavijesti i našim <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravilima o privatnosti</a> opisano je kako Stitch postupa s vašim podacima. Pozorno ih pročitajte.</p><p>Kada upotrebljavate Stitch, Google prikuplja vaše razgovore (uključujući upite, privitke i generirani rezultat obrade), povezane podatke o korištenju značajke i vaše povratne informacije. Google upotrebljava te podatke u skladu s našim <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravilima o privatnosti</a> za pružanje, poboljšanje i razvoj Googleovih proizvoda i usluga te tehnologija strojnog učenja. Pregledavatelji (uključujući obučene pregledavatelje naših davatelja usluga) u tu svrhu pregledavaju neke razgovore. Nemojte unositi povjerljive informacije za koje ne želite da ih vidi pregledavatelj ili da ih Google upotrebljava za poboljšanje Googleovog AI-ja.</p><p>Ako ne želite da se vaši budući razgovori upotrebljavaju za obučavanje naših generativnih AI modela, možete isključiti opciju u <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">postavkama</a> Stitcha. Ako odlučite pružiti povratne informacije, Google može upotrijebiti te povratne informacije i sav povezani sadržaj (npr. povezane razgovore) za obučavanje naših generativnih AI modela čak i ako ste isključili opciju.</p>',settingsHeader:"Dopusti obuku AI modela",settingsBody:'<p>Neka Google upotrebljava vaše buduće razgovore povezane sa Stitchem za obuku svojih generativnih AI modela. Isključivanje se ne odnosi na povratne informacije koje odlučite dati. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Saznajte više</a>.</p>'},Yq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">A Google Feltételei</a> és <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">használati irányelvei</a> vannak érvényben. Az adatkezelés gyakorlatát az <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Adatvédelmi közlemény</a> ismerteti. Beszélgetéseit és kódjait felülvizsgálhatjuk, és felhasználhatjuk a Google AI továbbfejlesztésére. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">További információ a választási lehetőségeiről</a>. A Stitch hibázhat, ezért ellenőrizze a válaszait, és <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">legyen körültekintő a kódok felhasználásakor</a>.</p>',privacyHeader:"Stitch Adatvédelmi közlemény",privacyBody:'<p>Legutóbbi frissítés: 2025. május 20.</p><p>A Stitch adatkezelési gyakorlatát ez a közlemény és az <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Adatvédelmi irányelveink</a> részletezik. Kérjük, figyelmesen olvassa el őket.</p><p>Amikor Ön a Stitch szolgáltatást használja, a Google gyűjti az Ön beszélgetéseit (többek között az utasításokat, a mellékleteket és a generált kimeneteket), a kapcsolódó funkcióhasználati információkat és az Ön visszajelzését. A Google az <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">adatvédelmi irányelveknek</a> megfelelően használja fel ezeket az adatokat többek között a Google-termékek és -szolgáltatások, valamint a gépi tanulási technológiák biztosításához, javításához és fejlesztéséhez. Ezen célokból felülvizsgálatot végző emberek (többek között szolgáltatóink képzett ellenőrei) áttekintenek bizonyos beszélgetéseket. Kérjük, ne adjon meg bizalmas információkat, amelyeket nem szeretne, hogy lássanak a felülvizsgálatot végző emberek, vagy a Google felhasználjon a Google AI továbbfejlesztéséhez.</p><p>Ha nem szeretné, hogy felhasználjuk a jövőbeli beszélgetéseit generatív AI-modelljeink betanítására, elutasíthatja ezt a Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">beállításaiban</a>. Visszajelzés küldése esetén a Google felhasználhatja a visszajelzést és a kapcsolódó tartalmakat (pl. a kapcsolódó beszélgetéseket) a generatív AI-modellek betanítására – még akkor is, ha Ön elutasította az adatai megosztását.</p>',settingsHeader:"AI-modell betanításának engedélyezése",settingsBody:'<p>Engedélyezheti a Google-nak a jövőbeli Stitch-beszélgetéseinek a generatív AI-modelljeinek betanítására való felhasználását. Az adatok megosztásának elutasítása nem vonatkozik az Ön által adott visszajelzésekre. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">További információ</a>.</p>'},Kq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Persyaratan Google</a> dan <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Kebijakan Penggunaan</a> berlaku. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Pemberitahuan Privasi</a> berisi penjelasan mengenai cara penanganan data Anda. Percakapan dan kode Anda mungkin akan ditinjau dan digunakan untuk meningkatkan kualitas AI Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Pelajari pilihan Anda</a>. Stitch dapat membuat kesalahan, jadi sebaiknya periksa kembali dan <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">gunakan kode dengan hati-hati</a>.</p>',privacyHeader:"Pemberitahuan Privasi Stitch",privacyBody:'<p>Terakhir diperbarui: 20 Mei 2025</p><p>Pemberitahuan ini dan <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Kebijakan Privasi</a> kami menjelaskan cara Stitch menangani data Anda. Harap baca dengan cermat.</p><p>Saat Anda menggunakan Stitch, Google akan mengumpulkan percakapan Anda (termasuk perintah dan lampiran, serta output yang dihasilkan), yang terkait dengan informasi penggunaan fitur serta masukan Anda. Google menggunakan data ini sesuai dengan <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Kebijakan Privasi</a> kami, termasuk untuk menyediakan, mengembangkan, serta meningkatkan kualitas produk, layanan, dan teknologi machine learning Google. Petugas peninjau (termasuk peninjau terlatih dari penyedia layanan kami) akan meninjau sebagian percakapan untuk tujuan ini. Jangan sertakan informasi rahasia yang seharusnya tidak dilihat peninjau atau digunakan Google untuk meningkatkan kualitas AI Google.</p><p>Jika Anda tidak ingin percakapan mendatang Anda digunakan untuk melatih model AI generatif kami, Anda dapat memilih tidak ikut di <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">setelan</a> Stitch. Jika Anda memilih untuk memberikan masukan, Google dapat menggunakan masukan tersebut beserta setiap konten terkait (misalnya, percakapan terkait) untuk melatih model AI generatif kami meskipun Anda telah memilih tidak ikut.</p>',settingsHeader:"Izinkan Pelatihan Model AI",settingsBody:'<p>Izinkan Google menggunakan percakapan mendatang Anda di Stitch untuk melatih model AI generatif. Pilihan tidak ikut tidak berlaku untuk masukan apa pun yang mungkin Anda berikan. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Pelajari lebih lanjut</a>.</p>'},Qq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Skilmálar</a> og <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">notkunarreglur</a> Google eiga við. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Upplýsingar um persónuvernd</a> lýsa því hvernig gögnin þín eru meðhöndluð. Hugsanlega verður farið yfir samtölin þín og kóða í því skyni að bæta gervigreind Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Nánar um val þitt</a>. Stitch getur gert mistök svo að þú skalt fara yfir öll svör og <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">nota kóða af varfærni</a>.</p>',privacyHeader:"Upplýsingar um persónuvernd Stitch",privacyBody:'<p>Síðast uppfært: 20. maí 2025</p><p>Þessar upplýsingar og <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">persónuverndarstefna</a> okkar lýsa því hvernig Stitch meðhöndlar gögnin þín. Lestu þær vandlega.</p><p>Þegar þú notar Stitch safnar Google samtölum þínum (þ.m.t. skipunum, viðhengjum og frálagi sem búið er til), upplýsingum um notkun tengdra eiginleika og ábendingum þínum. Google notar þessi gögn í samræmi við <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">persónuverndarstefnu</a> okkar, þ.m.t. til að veita, bæta og þróa vörur, þjónustur og vélnámstækni Google. Mannlegir yfirlesarar (þ.m.t. þjálfaðir yfirlesarar úr hópi þjónustuaðila okkar) fara yfir sum samtöl í þessu skyni. Ekki slá inn trúnaðarupplýsingar sem þú vilt ekki að yfirlesari sjái eða Google noti til að bæta gervigreind Google.</p><p>Ef þú vilt ekki að samtöl þín verði notuð til að þjálfa skapandi gervigreindarlíkön okkar héðan í frá geturðu afþakkað það í <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">stillingum</a> Stitch. Ef þú velur að senda inn ábendingu er Google heimilt að nota hana og allt efni tengt henni (t.d. tengd samtöl) til að þjálfa skapandi gervigreindarlíkön okkar, jafnvel þótt þú hafir afþakkað notkun samtala.</p>',settingsHeader:"Leyfa þjálfun gervigreindarlíkana",settingsBody:'<p>Leyfðu Google að nota samtölin þín í Stitch héðan í frá til að þjálfa skapandi gervigreindarlíkön sín. Afþökkun gildir ekki um ábendingar sem þú gætir veitt. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Nánar</a>.</p>'},Xq={banner:`<p>Si applicano i <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Termini Google</a> e le <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Norme sull'utilizzo</a>. L'<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Informativa sulla privacy</a> descrive le modalità del trattamento dei tuoi dati. Le tue conversazioni e il tuo codice potrebbero essere esaminati e utilizzati per migliorare Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Scopri di più sulle opzioni a tua disposizione</a>. Stitch può fare errori, quindi verifica le sue risposte e <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">usa il codice con cautela</a>.</p>`,privacyHeader:"Stitch Privacy Notice",privacyBody:`<p>Ultimo aggiornamento: 20 maggio 2025</p><p>Nella presente informativa e nelle nostre <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Norme sulla privacy</a> vengono descritte le modalità di trattamento dei tuoi dati in Stitch. Ti consigliamo di leggerle con attenzione.</p><p>Quando usi Stitch, Google raccoglie le conversazioni (inclusi prompt, allegati e output generati), le informazioni correlate sull'utilizzo delle funzionalità e il tuo feedback. Google utilizza questi dati in conformità alle sue <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Norme sulla privacy</a> per fornire, migliorare e sviluppare i propri prodotti, servizi e tecnologie di machine learning. I revisori (inclusi revisori esperti dei nostri fornitori di servizi) esaminano alcune conversazioni a questo scopo. Non includere informazioni riservate che non vorresti che un revisore vedesse o che Google utilizzasse per migliorare Google AI.</p><p>Se non vuoi che le tue conversazioni future vengano utilizzate per addestrare i nostri modelli di AI generativa, puoi ritirare il consenso nelle <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">impostazioni</a> di Stitch. Se scegli di fornire il tuo feedback, Google può utilizzarlo insieme ad altri contenuti associati (ad es. conversazioni correlate) per addestrare i suoi modelli di AI generativa anche se hai ritirato il consenso.</p>`,settingsHeader:"Consenti l'addestramento dei modelli di AI",settingsBody:'<p>Consenti a Google di utilizzare le tue conversazioni future su Stitch per addestrare i suoi modelli di AI generativa. Il ritiro del consenso non si applica a eventuali feedback che deciderai di fornire. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Scopri di più</a>.</p>'},Wq={banner:'<p>בכפוף <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">לתנאים</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">של</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google</a> ו<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">למדיניות</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">השימוש</a>. ב<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">הודעת</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">הפרטיות</a> מוסבר מה אנחנו עושים עם הנתונים. יכול להיות שנבדוק את הקוד והשיחות שלך ונשתמש בהם כדי לשפר את ה-AI מבית Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">כאן</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">מפורטות</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">כל</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">האפשרויות</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">שקשורות</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">לשמירת</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">נתונים</a>. ‫Stitch עלול לעשות טעויות אז חשוב לבדוק אותו טוב <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ולהשתמש</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">בקוד</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">בזהירות</a>.</p>',privacyHeader:"הודעת הפרטיות של Stitch",privacyBody:'<p>תאריך העדכון האחרון: 20 במאי 2025</p><p>בהודעה הזו וב<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">מדיניות</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">הפרטיות</a> שלנו מוסבר מה עושים עם הנתונים ב-Stitch. חשוב לקרוא את כל הפרטים בעיון.</p><p>כשמשתמשים ב-Stitch, ‏Google אוספת את נתוני השיחות (כולל הנחיות, קבצים מצורפים ותוצרים), מידע על השימוש בתכונות קשורות ומשוב מהמשתמשים. ‫Google משתמשת בנתונים האלה בהתאם ל<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">מדיניות</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">הפרטיות</a> כדי לספק, לשפר ולפתח את טכנולוגיות למידת המכונה, המוצרים והשירותים שלה. כדי שנוכל לעשות את זה, בודקים אנושיים (בין היתר מטעם ספקי השירות שלנו) עוברים על חלק מהשיחות. חשוב לא להזין מידע סודי שלא רוצים שהבודקים יראו או ש-Google תשתמש בו כדי לשפר את ה-AI מבית Google.</p><p><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">בהגדרות</a> של Stitch אפשר לבחור שהשיחות העתידיות לא ישמשו לאימון המודלים של ה-AI הגנרטיבי. אם שולחים משוב, Google יכולה להשתמש בו ובתוכן הקשור (למשל שיחות) כדי לאמן את המודלים של ה-AI הגנרטיבי, גם אם המשתמש הגדיר שהשיחות לא ישמשו לאימון המודלים.</p>',settingsHeader:"אישור לאימון מודלים של AI",settingsBody:'<p>‫Google תוכל להשתמש בשיחות העתידיות ב-Stitch כדי לאמן את המודלים של ה-AI הגנרטיבי. ‫Google תוכל להשתמש במשוב של משתמשים גם אם הם יבטלו את האישור לשימוש בשיחות ובקוד לאימון המודלים. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">מידע</a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">נוסף</a></p>'},Jq={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google 利用規約</a>と<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">使用に関するポリシー</a>が適用されます。<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">プライバシーに関するお知らせ</a>では、お客様のデータの取り扱いについて説明しています。会話の内容やコードを確認し、Google AI の改善に活用させていただく場合があります。<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">お客様が選択できる項目の詳細</a>をご確認ください。Stitch の情報には誤りが含まれている場合があるため、内容をよくご確認ください。また、<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">コードは注意してご利用ください</a>。</p>',privacyHeader:"Stitch のプライバシーに関するお知らせ（静的ページ）:",privacyBody:'<p>最終更新日: 2025 年 5 月 20 日</p><p>このお知らせと Google の<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">プライバシー ポリシー</a>では、Stitch でのデータの取り扱いについて説明しています。以下の内容をよくご確認ください。</p><p>Stitch を使用する際、Google はユーザーの会話（プロンプトや添付ファイル、生成された出力を含む）、関連機能の使用情報、フィードバックを収集します。Google では、<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">プライバシー ポリシー</a>に従って、これらのデータを Google のプロダクト、サービス、機械学習技術の提供、改善、開発などの目的で使用します。これらの目的のために、人間のレビュアー（トレーニングを受けた Google のサービス プロバイダのレビュアーを含む）が会話を確認することがあります。レビュアーの目に触れることや、Google AI の改善のために Google によって使用されることを望まない、機密性の高い情報は入力しないでください。</p><p>今後の会話が Google の生成 AI モデルのトレーニングに使用されることを望まない場合は、Stitch の<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">設定</a>でオプトアウトできます。ただし、オプトアウトしても、フィードバックを提供することを選択した場合は、Google がそのフィードバックと関連するあらゆるコンテンツ（関連する会話など）を Google の生成 AI モデルのトレーニングに使用する場合があります。</p>',settingsHeader:"AI モデルのトレーニングを許可する",settingsBody:'<p>Google の生成 AI モデルのトレーニングのために、Stitch での今後の会話やコードを Google が使用することを許可します。フィードバックを提供することを選択した場合は、オプトアウトしても、選択したフィードバックには適用されません。<a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">詳細</a></p>'},$q={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google ನಿಯಮಗಳು</a> ಮತ್ತು <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ಬಳಕೆಯ ನೀತಿ</a> ಅನ್ವಯವಾಗುತ್ತದೆ. ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಹೇಗೆ ನಿರ್ವಹಿಸಲಾಗುತ್ತದೆ ಎಂಬುದನ್ನು <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">ಗೌಪ್ಯತಾ ಸೂಚನೆ</a> ವಿವರಿಸುತ್ತದೆ. ನಿಮ್ಮ ಸಂಭಾಷಣೆಗಳು ಮತ್ತು ಕೋಡ್ ಅನ್ನು ಪರಿಶೀಲಿಸಬಹುದು ಮತ್ತು Google AI ಅನ್ನು ಸುಧಾರಿಸಲು ಬಳಸಬಹುದು. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ನಿಮ್ಮ ಆಯ್ಕೆಗಳ ಕುರಿತು ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ</a>. Stitch ತಪ್ಪುಗಳನ್ನು ಮಾಡಬಹುದು, ಹಾಗಾಗಿ ಇದನ್ನು ಮತ್ತೊಮ್ಮೆ ಪರಿಶೀಲಿಸಿ ಮತ್ತು <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ಎಚ್ಚರಿಕೆಯಿಂದ ಕೋಡ್ ಬಳಸಿ</a>.</p>',privacyHeader:"Stitch ಗೌಪ್ಯತಾ ಸೂಚನೆ",privacyBody:'<p>ಕೊನೆಯದಾಗಿ ಅಪ್‌ಡೇಟ್ ಮಾಡಿರುವುದು: 20 ಮೇ 2025</p><p>Stitch ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಹೇಗೆ ನಿರ್ವಹಿಸುತ್ತದೆ ಎಂಬುದನ್ನು ಈ ಸೂಚನೆ ಮತ್ತು ನಮ್ಮ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">ಗೌಪ್ಯತೆ ನೀತಿಯು</a> ವಿವರಿಸುತ್ತದೆ. ಅವುಗಳನ್ನು ಜಾಗರೂಕತೆಯಿಂದ ಓದಿ.</p><p>ನೀವು Stitch ಅನ್ನು ಬಳಸುವಾಗ, Google ನಿಮ್ಮ ಸಂಭಾಷಣೆಗಳು (ಪ್ರಾಂಪ್ಟ್‌ಗಳು ಮತ್ತು ಲಗತ್ತುಗಳು ಮತ್ತು ಜನರೇಟ್ ಮಾಡಲಾದ ಔಟ್‌ಪುಟ್ ಸೇರಿದಂತೆ), ಸಂಬಂಧಿಸಿದ ಫೀಚರ್ ಬಳಕೆಯ ಮಾಹಿತಿ ಮತ್ತು ನಿಮ್ಮ ಫೀಡ್‌ಬ್ಯಾಕ್ ಅನ್ನು ಸಂಗ್ರಹಿಸುತ್ತದೆ. Google ಉತ್ಪನ್ನಗಳು ಮತ್ತು ಸೇವೆಗಳು ಹಾಗೂ ಮಷಿನ್ ಲರ್ನಿಂಗ್ ತಂತ್ರಜ್ಞಾನಗಳನ್ನು ಒದಗಿಸಲು, ಸುಧಾರಿಸಲು ಮತ್ತು ಅಭಿವೃದ್ಧಿಪಡಿಸಲು ಸೇರಿದಂತೆ ನಮ್ಮ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">ಗೌಪ್ಯತೆ ನೀತಿಗೆ</a> ಅನುಗುಣವಾಗಿ Google ಈ ಡೇಟಾವನ್ನು ಬಳಸುತ್ತದೆ. ಮಾನವ ರಿವ್ಯೂವರ್‌ಗಳು (ನಮ್ಮ ಸೇವೆ ಒದಗಿಸುವವರ ತರಬೇತಿ ಪಡೆದ ರಿವ್ಯೂವರ್‌ಗಳು ಸೇರಿದಂತೆ) ಈ ಉದ್ದೇಶಗಳಿಗಾಗಿ ಕೆಲವು ಸಂಭಾಷಣೆಗಳನ್ನು ರಿವ್ಯೂ ಮಾಡುತ್ತಾರೆ. ರಿವ್ಯೂವರ್ ನೋಡಬಾರದು ಅಥವಾ Google AI ಅನ್ನು ಸುಧಾರಿಸಲು Google ಬಳಸಬಾರದು ಎಂದು ನೀವು ಬಯಸುವ ಗೌಪ್ಯ ಮಾಹಿತಿಯನ್ನು ನಮೂದಿಸಬೇಡಿ.</p><p>ನಿಮ್ಮ ಭವಿಷ್ಯದ ಸಂಭಾಷಣೆಗಳನ್ನು ನಮ್ಮ ಜನರೇಟಿವ್ AI ಮಾಡಲ್‌ಗಳಿಗೆ ತರಬೇತಿ ನೀಡುವುದಕ್ಕೆ ಬಳಸಲು ನೀವು ಬಯಸದಿದ್ದರೆ, ನಿಮ್ಮ Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ</a> ನೀವು ಹೊರಗುಳಿಯಬಹುದು. ನೀವು ಫೀಡ್‌ಬ್ಯಾಕ್ ಒದಗಿಸುವುದನ್ನು ಆಯ್ಕೆಮಾಡಿದರೆ, ನೀವು ಹೊರಗುಳಿದಿದ್ದರೂ ಸಹ ನಮ್ಮ ಜನರೇಟಿವ್ AI ಮಾಡಲ್‌ಗಳಿಗೆ ತರಬೇತಿ ನೀಡಲು Google ಆ ಫೀಡ್‌ಬ್ಯಾಕ್ ಅನ್ನು ಮತ್ತು ಯಾವುದೇ ಸಂಬಂಧಿಸಿದ ಕಂಟೆಂಟ್ (ಉದಾ. ಸಂಬಂಧಿಸಿದ ಸಂಭಾಷಣೆಗಳು) ಅನ್ನು ಬಳಸಬಹುದು.</p>',settingsHeader:"AI ಮಾಡಲ್ ತರಬೇತಿಗೆ ಅನುಮತಿಸಿ",settingsBody:'<p>ತನ್ನ ಜನರೇಟಿವ್ AI ಮಾಡಲ್‌ಗಳಿಗೆ ತರಬೇತಿ ನೀಡಲು ನಿಮ್ಮ ಭವಿಷ್ಯದ Stitch ಸಂಭಾಷಣೆಗಳು ಮತ್ತು ಕೋಡ್ ಅನ್ನು ಬಳಸುವುದಕ್ಕೆ Google ಗೆ ಅನುಮತಿಸಿ. ನೀವು ಒದಗಿಸಲು ಆಯ್ಕೆಮಾಡಬಹುದಾದ ಯಾವುದೇ ಫೀಡ್‌ಬ್ಯಾಕ್‌ಗೆ ಹೊರಗುಳಿಯುವಿಕೆ ಅನ್ವಯವಾಗುವುದಿಲ್ಲ. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ</a>.</p>'},eY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google 약관</a> 및 <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">사용 정책</a>이 적용됩니다. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">개인정보처리방침</a>에는 사용자의 데이터가 처리되는 방식이 설명되어 있습니다. 사용자의 대화 및 코드가 Google AI 개선을 위해 검토 및 사용될 수 있습니다. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">사용자의 선택 사항에 대해 자세히 알아보세요</a>. Stitch는 실수할 수 있으므로, 결과물을 다시 한번 확인하고 <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">신중하게 코드를 사용</a>하시기 바랍니다.</p>',privacyHeader:"Stitch 개인정보처리방침",privacyBody:'<p>최종 업데이트: 2025년 5월 20일</p><p>본 고지와 <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">개인정보처리방침</a>에는 Stitch에서 사용자의 데이터를 처리하는 방식이 설명되어 있습니다. 주의 깊게 읽어 보시기 바랍니다.</p><p>Stitch 사용 시 Google에서는 사용자의 대화(프롬프트 및 첨부파일, 생성된 출력 등), 관련 기능 사용 정보, 사용자 의견을 수집합니다. Google은 이 데이터를 Google의 <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">개인정보처리방침</a>에 따라 Google 제품 및 서비스와 머신러닝 기술의 제공, 개선, 개발 등에 사용합니다. 이러한 목적으로 인적 검토자(서비스 제공업체의 인적 검토자 포함)가 일부 대화를 검토합니다. 검토자가 보거나 Google에서 Google AI 개선에 사용하기를 원치 않는 기밀 정보를 입력하지 마시기 바랍니다.</p><p>향후 대화가 생성형 AI 모델을 학습시키는 데 사용되지 않도록 하려면 Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">설정</a>에서 데이터 제공을 거부하세요. 의견을 제공하는 경우, 데이터 제공을 거부했더라도 Google에서 생성형 AI 모델을 학습시키는 데 이 의견과 관련 콘텐츠(예: 관련 대화)를 사용할 수 있습니다.</p>',settingsHeader:"AI 모델 학습 허용",settingsBody:'<p>Google에서 생성형 AI 모델을 학습시키는 데 향후 Stitch 대화를 사용하도록 허용합니다. 직접 제공한 의견에는 데이터 제공 거부가 적용되지 않습니다. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">자세히 알아보기</a></p>'},tY={banner:'<p>Taikomos <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">„Google“ sąlygos</a> ir <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">naudojimo politika</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Privatumo pranešime</a> aprašoma, kaip tvarkomi jūsų duomenys. Jūsų pokalbiai ir kodas gali būti peržiūrėti ir naudojami siekiant tobulinti „Google“ DI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Sužinokite apie galimus pasirinkimus</a>. „Stitch“ gali klysti, todėl dar kartą patikrinkite ir <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">naudokite kodą apdairiai</a>.</p>',privacyHeader:"„Stitch“ privatumo pranešimas",privacyBody:'<p>Paskutinį kartą atnaujinta: 2025m. gegužės 20 d.</p><p>Šiame pranešime ir mūsų <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privatumo politikoje</a> aprašoma, kaip „Stitch“ tvarko jūsų duomenis. Atidžiai perskaitykite.</p><p>Kai naudojate „Stitch“, „Google“ renka jūsų pokalbius (įskaitant užklausas, priedus ir sugeneruotas išvestis), susijusią funkcijų naudojimo informaciją bei jūsų atsiliepimus. „Google“ šiuos duomenis naudoja pagal savo <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">privatumo politiką</a>, kad galėtų teikti, tobulinti ir kurti „Google“ produktus, paslaugas bei mašininio mokymosi technologijas. Tikrinantys žmonės (įskaitant mūsų paslaugų teikėjų tikrinančius žmones) peržiūri kai kuriuos pokalbius šiais tikslais. Neįveskite konfidencialios informacijos, kurios nenorėtumėte atskleisti tikrintojui ar leisti naudoti „Google“ DI tobulinimo tikslais.</p><p>Jei nenorite, kad būsimi pokalbiai būtų naudojami generatyviniams DI modeliams mokyti, galite atsisakyti „Stitch“ <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">nustatymuose</a>. Jei pasirinksite teikti atsiliepimus, „Google“ galės naudoti tuos atsiliepimus ir visą susijusį turinį (pvz., susijusius pokalbius) generatyviniams DI modeliams mokyti, net jei atsisakysite.</p>',settingsHeader:"Leidimas mokyti DI modelius",settingsBody:'<p>Leiskite „Google“ naudoti būsimus „Stitch“ pokalbius generatyviniams DI modeliams mokyti. Atsisakymas netaikomas jokiems atsiliepimams, kuriuos nuspręsite pateikti. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Sužinokite daugiau</a>.</p>'},aY={banner:'<p>Ir spēkā <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google noteikumi</a> un <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">izmantošanas politika</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Konfidencialitātes paziņojumā</a> ir aprakstīts, kā tiek apstrādāti jūsu dati. Jūsu sarunas un kods var tikt pārskatīts un izmantots Google MI uzlabošanai. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Uzziniet par jums pieejamajām izvēles iespējām</a>. Stitch var pieļaut kļūdas, tādēļ pārbaudiet to un <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">izmantojiet kodu piesardzīgi</a>.</p>',privacyHeader:"Stitch konfidencialitātes paziņojums",privacyBody:'<p>Pēdējoreiz atjaunināts 2025. gada 20. maijā</p><p>Šajā paziņojumā un mūsu <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">konfidencialitātes politikā</a> ir aprakstīts, kā Stitch apstrādā jūsu datus. Lūdzu, rūpīgi izlasiet šo informāciju.</p><p>Kad izmantojat Stitch, Google vāc jūsu sarunu datus (tostarp uzvednes, pielikumus un ģenerēto izvades saturu), saistīto funkciju lietojuma informāciju un jūsu atsauksmes. Google izmanto šos datus saskaņā ar <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">konfidencialitātes politiku</a>, tostarp, lai nodrošinātu, uzlabotu un izstrādātu Google produktus, pakalpojumus un mašīnmācīšanās tehnoloģijas. Šiem mērķiem pārskatītāji (tostarp profesionāli pārskatītāji no mūsu pakalpojumu sniedzējiem) pārskatīs dažas sarunas. Nenorādiet konfidenciālu informāciju, kas, jūsuprāt, pārskatītājiem nebūtu jāredz vai uzņēmumam Google nebūtu jāizmanto Google MI uzlabošanai.</p><p>Ja nevēlaties, lai jūsu turpmākās sarunas tiktu izmantotas mūsu ģeneratīvo MI modeļu apmācībai, Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">iestatījumos</a> varat no tā atteikties. Ja izvēlēsieties sniegt atsauksmes, Google var izmantot šīs atsauksmes un ar tām saistīto saturu (piemēram, saistītās sarunas) mūsu ģeneratīvo MI modeļu apmācībai, pat ja atteicāties no citu datu sniegšanas.</p>',settingsHeader:"Atļaut MI modeļu apmācību",settingsBody:'<p>Atļaujiet uzņēmumam Google izmantot jūsu turpmākās Stitch sarunas ģeneratīvo MI modeļu apmācībai. Atteikšanās neattiecas uz jūsu sniegtajām atsauksmēm. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Uzziniet vairāk</a>.</p>'},nY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google നിബന്ധനങ്ങൾ</a>, <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ഉപയോഗം സംബന്ധിച്ച നയം</a> എന്നിവ ബാധകമാണ്. നിങ്ങളുടെ ഡാറ്റ എങ്ങനെ കൈകാര്യം ചെയ്യുന്നുവെന്ന് <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">സ്വകാര്യതാ അറിയിപ്പ്</a> വിവരിക്കുന്നു. നിങ്ങളുടെ സംഭാഷണങ്ങളും കോഡും അവലോകനം ചെയ്‌ത് Google AI മെച്ചപ്പെടുത്താൻ ഉപയോഗിച്ചേക്കാം. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">നിങ്ങളുടെ ചോയ്‌സുകളെ കുറിച്ച് അറിയുക</a>. Stitch-ന് തെറ്റുകൾ സംഭവിക്കാം, അതിനാൽ ഫലങ്ങൾ വീണ്ടും പരിശോധിച്ച് <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">കോഡ് ജാഗ്രതയോടെ ഉപയോഗിക്കുക</a>.</p>',privacyHeader:"Stitch സ്വകാര്യതാ അറിയിപ്പ്",privacyBody:'<p>അവസാനം അപ്ഡേറ്റ് ചെയ്തത്: 2025 മെയ് 20</p><p>Stitch എങ്ങനെയാണ് നിങ്ങളുടെ ഡാറ്റ കൈകാര്യം ചെയ്യുന്നതെന്ന് ഈ അറിയിപ്പും ഞങ്ങളുടെ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">സ്വകാര്യതാ നയവും</a> വിവരിക്കുന്നു. അവ ശ്രദ്ധാപൂർവം വായിക്കുക.</p><p>നിങ്ങൾ Stitch ഉപയോഗിക്കുമ്പോൾ, Google നിങ്ങളുടെ സംഭാഷണങ്ങളും (പ്രോംപ്റ്റുകളും അറ്റാച്ച്മെന്റുകളും, ജനറേറ്റ് ചെയ്ത ഔട്ട്പുട്ട് എന്നിവ ഉൾപ്പെടെ) ഫീച്ചർ ഉപയോഗത്തെ കുറിച്ചുള്ള അനുബന്ധ വിവരങ്ങളും നിങ്ങളുടെ ഫീഡ്‌ബാക്കും ശേഖരിക്കുന്നു. Google ഉൽപ്പന്നങ്ങളും സേവനങ്ങളും മെഷീൻ ലേണിംഗ് സാങ്കേതികവിദ്യകളും ലഭ്യമാക്കാനും മെച്ചപ്പെടുത്താനും വികസിപ്പിക്കാനും ഉൾപ്പെടെ, ഞങ്ങളുടെ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">സ്വകാര്യതാ നയത്തിന്</a> അനുസൃതമായി Google ഈ ഡാറ്റ ഉപയോഗിക്കുന്നു. ഈ ആവശ്യകതകൾക്കായി, റിവ്യൂവർമാർ (ഞങ്ങളുടെ സേവന ദാതാക്കളിൽ നിന്നുള്ള പരിശീലനം ലഭിച്ച റിവ്യൂവർമാർ ഉൾപ്പെടെ) ചില സംഭാഷണങ്ങൾ അവലോകനം ചെയ്യും. റിവ്യൂവർ കാണരുതെന്നോ Google AI മെച്ചപ്പെടുത്താൻ Google ഉപയോഗിക്കരുതെന്നോ കരുതുന്ന രഹസ്യാത്മക വിവരങ്ങളൊന്നും നൽകരുത്.</p><p>നിങ്ങൾ ഭാവിയിൽ നടത്തുന്ന സംഭാഷണങ്ങൾ ഞങ്ങളുടെ ജനറേറ്റീവ് AI മോഡലുകളെ പരിശീലിപ്പിക്കാൻ ഉപയോഗിക്കുന്നതിനോട് താൽപ്പര്യമില്ലെങ്കിൽ, നിങ്ങളുടെ Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ക്രമീകരണത്തിൽ</a> ഒഴിവാക്കാം. നിങ്ങൾ ഫീഡ്ബാക്ക് നൽകാൻ തിരഞ്ഞെടുക്കുകയാണെങ്കിൽ, നിങ്ങൾ ഒഴിവാക്കിയിട്ടുണ്ടെങ്കിൽ പോലും ഞങ്ങളുടെ ജനറേറ്റീവ് AI മോഡലുകളെ പരിശീലിപ്പിക്കാനായി ആ ഫീഡ്ബാക്കും അനുബന്ധ ഉള്ളടക്കമുണ്ടെങ്കിൽ അവയും (ഉദാ. അനുബന്ധ സംഭാഷണങ്ങൾ) ഉപയോഗിക്കാൻ Google-ന് കഴിയും.</p>',settingsHeader:"AI മോഡൽ പരിശീലനം അനുവദിക്കുക",settingsBody:'<p>ജനറേറ്റീവ് AI മോഡലുകളെ പരിശീലിപ്പിക്കാനായി, ഭാവിയിൽ നിങ്ങൾ നടത്തുന്ന Stitch സംഭാഷണങ്ങൾ ഉപയോഗിക്കാൻ Google-നെ അനുവദിക്കുക. നിങ്ങൾ ഫീഡ്ബാക്ക് നൽകാൻ തിരഞ്ഞെടുക്കുകയാണെങ്കിൽ ഒഴിവാക്കൽ അതിന് ബാധകമാകില്ല. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">കൂടുതലറിയുക</a>.</p>'},rY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google अटी</a> आणि <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">वापर धोरण</a> लागू. तुमचा डेटा कसा हाताळला जातो याचे वर्णन <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">गोपनीयता नोटिस</a> करते. तुमच्या संभाषणांचे आणि कोडचे पुनरावलोकन केले जाऊ शकते व ते Google AI मध्ये सुधारणा करण्यासाठी वापरले जाऊ शकतात. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">तुमच्या निवडींबद्दल जाणून घ्या</a>. Stitch चुका करू शकते, त्यामुळे ते दोनदा तपासा आणि <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">कोड काळजीपूर्वक वापरणे</a> हे करा.</p>',privacyHeader:"Stitch गोपनीयता नोटिस",privacyBody:'<p>शेवटचे अपडेट केले: २० मे २०२५</p><p>ही नोटिस आणि आमचे <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">गोपनीयता धोरण</a> Stitch तुमचा डेटा कसा हाताळतात याचे वर्णन करतात. कृपया या गोष्टी काळजीपूर्वक वाचा.</p><p>तुम्ही Stitch वापरता, तेव्हा Google तुमची संभाषणे (प्रॉम्प्ट आणि अटॅचमेंट व जनरेट केलेल्या आउटपुटच्या समावेशासह), संबंधित वैशिष्ट्याची वापर माहिती आणि तुमचा फीडबॅक गोळा करते. Google हे आमचे <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">गोपनीयता धोरण</a> याच्याशी सुसंगत राहून हा डेटा वापरते, ज्यामध्ये Google उत्पादने आणि सेवा व मशीन लर्निंग तंत्रज्ञाने पुरवणे, त्यांमध्ये सुधारणा करणे आणि ती विकसित करणे याचा समावेश आहे. मानवी परीक्षणकर्ते (आमच्या सेवा पुरवठादारांकडील प्रशिक्षित परीक्षणकर्त्यांच्या समावेशासह) या उद्देशांसाठी काही संभाषणांचे पुनरावलोकन करतात. कृपया परीक्षणकर्त्याने पाहू नये किंवा Google ने Google AI मध्ये सुधारणा करण्यासाठी वापरू नये असे तुम्हाला वाटत असलेली गोपनीय माहिती एंटर करू नका.</p><p>तुम्हाला तुमची भविष्यातील संभाषणे आमच्या जनरेटिव्ह AI मॉडेलना प्रशिक्षण देण्यासाठी वापरायची नसल्यास, तुम्ही तुमच्या Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">सेटिंग्ज</a> मध्ये निवड रद्द करू शकता. तुम्ही फीडबॅक पुरवण्याचे निवडल्यास, तुम्ही निवड रद्द केलेली असली, तरीही Google आमच्या जनरेटिव्ह AI मॉडेलना प्रशिक्षण देण्यासाठी तो फीडबॅक आणि संबंधित असलेला कोणताही आशय वापरू शकते (उदा., संबंधित संभाषणे).</p>',settingsHeader:"AI मॉडेलला प्रशिक्षण देण्याची अनुमती द्या",settingsBody:'<p>Google ला त्यांच्या जनरेटिव्ह AI मॉडेलना प्रशिक्षण देण्यासाठी तुमची भविष्यातील Stitch संभाषणे वापरू द्या. तुम्ही पुरवता अशा कोणत्याही फीडबॅकवर निवड रद्द करणे लागू होत नाही. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">अधिक जाणून घ्या</a>.</p>'},oY={banner:'<p>Tertakluk pada <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Syarat Google</a> dan <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Dasar Pengguna</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Notis Privasi</a> menerangkan cara data anda dikendalikan. Perbualan dan kod anda boleh disemak dan digunakan untuk meningkatkan Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Ketahui pilihan anda</a>. Stitch mungkin melakukan kesilapan, maka buat semakan semula dan <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">gunakan kod dengan berhati-hati</a>.</p>',privacyHeader:"Notis Privasi Stitch",privacyBody:'<p>Kemaskinian terakhir: 20 Mei 2025</p><p>Notis ini dan <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Dasar Privasi</a> kami menerangkan cara Stitch mengendalikan data anda. Sila baca notis dan dasar tersebut dengan berhati-hati.</p><p>Apabila anda menggunakan Stitch, Google akan mengumpulkan perbualan anda (termasuk gesaan dan lampiran serta output yang dijana), maklumat penggunaan ciri yang berkaitan, dan maklum balas anda. Google menggunakan data ini, selaras dengan <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Dasar Privasi</a> kami, termasuk untuk menyediakan, meningkatkan dan membangunkan produk serta perkhidmatan Google dan teknologi pembelajaran mesin. Jurusemak (termasuk jurusemak terlatih dari penyedia perkhidmatan kami) menyemak sesetengah perbualan untuk tujuan ini. Jangan masukkan maklumat sulit yang anda tidak mahu dilihat oleh jurusemak atau digunakan oleh Google untuk meningkatkan Google AI.</p><p>Jika anda tidak mahu perbualan masa hadapan anda digunakan untuk melatih model AI generatif kami, anda boleh menarik diri dalam <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">tetapan</a> Stitch anda. Jika anda memilih untuk memberikan maklum balas, Google boleh menggunakan maklum balas tersebut dan sebarang kandungan yang berkaitan (mis., perbualan yang berkaitan) untuk melatih model AI generatif kami walaupun anda telah menarik diri.</p>',settingsHeader:"Benarkan Latihan Model AI",settingsBody:'<p>Benarkan Google menggunakan perbualan Stitch masa hadapan anda untuk melatih model AI generatif Google. Penarikan diri tidak terpakai pada sebarang maklum balas yang anda pilih untuk diberikan. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Ketahui lebih lanjut</a>.</p>'},iY={banner:'<p>De <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Servicevoorwaarden van Google</a> en het <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Beleid tegen verboden gebruik van AI</a> zijn van toepassing. In de <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Privacyverklaring</a> wordt beschreven hoe we omgaan met uw gegevens. Uw gesprekken en code kunnen worden beoordeeld en gebruikt om AI van Google te verbeteren. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Meer informatie over uw keuzes</a>. Stitch kan fouten maken, dus dubbelcheck het en <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">wees voorzichtig met het gebruik van code</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Laatste update: 20 mei 2025</p><p>In deze verklaring en ons <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacybeleid</a> wordt beschreven hoe Stitch uw gegevens verwerkt. Lees ze zorgvuldig door.</p><p>Als u Stitch gebruikt, verzamelt Google uw gesprekken (inclusief prompts, bijlagen en gegenereerde uitvoer), informatie over het gebruik van gerelateerde functies en uw feedback. Google gebruikt deze gegevens in overeenstemming met ons <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacybeleid</a>, onder meer om producten en services van Google en machinelearning-technologieën te leveren, te verbeteren en te ontwikkelen. Menselijke reviewers (waaronder reviewers van onze serviceproviders) beoordelen sommige gesprekken voor deze doeleinden. Verstrek geen vertrouwelijke informatie die u niet zichtbaar wilt maken voor reviewers of waarvan u niet wilt dat Google deze gebruikt om AI van Google te verbeteren.</p><p>Als u niet wilt dat uw toekomstige gesprekken worden gebruikt om onze generatieve AI-modellen te trainen, kunt u uw toestemming intrekken in de <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">instellingen</a> van Stitch. Als u ervoor kiest om feedback te geven, kan Google deze feedback en alle bijbehorende content (zoals gerelateerde gesprekken) gebruiken om onze generatieve AI-modellen te trainen, zelfs als u uw toestemming heeft ingetrokken.</p>',settingsHeader:"Trainen van AI-modellen toestaan",settingsBody:'<p>Laat Google uw toekomstige Stitch-gesprekken gebruiken om generatieve AI-modellen te trainen. Als u uw toestemming intrekt, is dit niet van toepassing op eventuele feedback die u verstrekt. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Meer informatie</a>.</p>'},sY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googles vilkår</a> og <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">retningslinjene for bruk</a> gjelder. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Merknaden om personvern</a> beskriver hvordan dataene dine håndteres. Samtalene dine og koden din kan bli gjennomgått og brukt for å gjøre AI fra Google bedre. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Finn ut mer om valgene du har</a>. Stitch kan gjøre feil, så du bør dobbeltsjekke resultatene og <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">være forsiktig når du bruker kode</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Sist oppdatert: 20. mai 2025</p><p>Dette varselet og <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">personvernreglene</a> våre beskriver hvordan Stitch håndterer dataene dine. Du bør lese dem nøye.</p><p>Når du bruker Stitch, samler Google inn samtalene dine (deriblant forespørsler, vedlegg og utdata som genereres), relatert informasjon om bruk av funksjoner og tilbakemeldinger fra deg. Google bruker disse dataene, i samsvar med <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">personvernreglene</a> våre, for å levere, forbedre og utvikle Googles produkter, tjenester og maskinlæringsteknologi. Menneskelige evaluerere (inkludert opplærte evaluerere fra tjenesteleverandørene våre) går gjennom enkelte samtaler for disse formålene. Du bør ikke legge inn konfidensiell informasjon som du ikke vil at evaluerere skal se eller Google skal bruke for å forbedre AI fra Google.</p><p>Hvis du ikke vil at de fremtidige samtalene dine skal brukes til å lære opp våre generative AI-modeller, kan du velge det bort i <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">innstillingene</a> for Stitch. Hvis du velger å gi tilbakemeldinger, kan Google bruke dem og eventuelt tilhørende innhold (f.eks. relaterte samtaler) til å lære opp de generative AI-modellene våre, selv om du har valgt dette bort.</p>',settingsHeader:"Gi tillatelse til opplæring av AI-modeller",settingsBody:'<p>La Google bruke fremtidige samtaler med Stitch til å lære opp generative AI-modeller. Selv om du velger dette bort, kan tilbakemeldinger du eventuelt gir, fortsatt brukes. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Finn ut mer</a>.</p>'},lY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google ସେବାର ସର୍ତ୍ତାବଳୀ</a> ଏବଂ <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">ବ୍ୟବହାର ନୀତି</a> ଲାଗୁ ହୁଏ। ଆପଣଙ୍କ ଡାଟାକୁ କିପରି ପରିଚାଳନା କରାଯାଏ ତାହା <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">ଗୋପନୀୟତା ନୋଟିସ</a> ବର୍ଣ୍ଣନା କରେ। ଆପଣଙ୍କ ବାର୍ତ୍ତାଳାପ ଓ କୋଡକୁ ସମୀକ୍ଷା କରାଯାଇପାରେ ଏବଂ Google AI ଉନ୍ନତ କରିବାକୁ ବ୍ୟବହାର କରାଯାଇପାରେ। <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ଆପଣଙ୍କ ପସନ୍ଦଗୁଡ଼ିକ ବିଷୟରେ ଜାଣନ୍ତୁ</a>। Stitch ଭୁଲ କରିପାରେ, ତେଣୁ ଏହାକୁ ଦୁଇଥର-ଯାଞ୍ଚ କରନ୍ତୁ ଏବଂ <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ସତର୍କତାର ସହ କୋଡ ବ୍ୟବହାର କରନ୍ତୁ</a>।</p>',privacyHeader:"Stitch ଗୋପନୀୟତା ନୋଟିସ",privacyBody:'<p>ଗତ ଥର ଅପଡେଟ ହୋଇଛି: ମଇ 20, 2025</p><p>Stitch ଆପଣଙ୍କ ଡାଟାକୁ କିପରି ପରିଚାଳନା କରେ ତାହା ଏହି ନୋଟିସ ଏବଂ ଆମ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">ଗୋପନୀୟତା ନୀତି</a> ବର୍ଣ୍ଣନା କରେ। ଦୟାକରି ସେଗୁଡ଼ିକୁ ଧ୍ୟାନର ସହ ପଢ଼ନ୍ତୁ।</p><p>ଆପଣ Stitchକୁ ବ୍ୟବହାର କଲେ, Google ଆପଣଙ୍କର ବାର୍ତ୍ତାଳାପ (ପ୍ରମ୍ପ୍ଟ ଓ ଆଟାଚମେଣ୍ଟ ଏବଂ ଜେନେରେଟ ହୋଇଥିବା ଆଉଟପୁଟ ସମେତ), ସମ୍ବନ୍ଧିତ ଫିଚର ବ୍ୟବହାର ସୂଚନା ଏବଂ ଆପଣଙ୍କ ମତାମତ ସଂଗ୍ରହ କରେ। Google ଏହି ଡାଟାକୁ ଆମ <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">ଗୋପନୀୟତା ନୀତି</a> ସହ ସୁସଙ୍ଗତ ଭାବେ ବ୍ୟବହାର କରେ, ଯେଉଁଥିରେ Google ପ୍ରଡକ୍ଟ ଓ ସେବା ଏବଂ ମେସିନ ଲର୍ଣ୍ଣିଂ ଟେକ୍ନୋଲୋଜିଗୁଡ଼ିକ ପ୍ରଦାନ, ଉନ୍ନତ ଓ ଡେଭେଲପ କରିବା ଅନ୍ତର୍ଭୁକ୍ତ। ମାନବ ସମୀକ୍ଷକମାନେ (ଆମର ସେବା ପ୍ରଦାନକାରୀଙ୍କ ତାଲିମପ୍ରାପ୍ତ ସମୀକ୍ଷକମାନଙ୍କ ସମେତ) ଏହି ଉଦ୍ଦେଶ୍ୟଗୁଡ଼ିକ ପାଇଁ କିଛି ବାର୍ତ୍ତାଳାପର ସମୀକ୍ଷା କରନ୍ତି। ଜଣେ ସମୀକ୍ଷକ ଦେଖିବା ବା Google AIକୁ ଉନ୍ନତ କରିବା ପାଇଁ Google ବ୍ୟବହାର କରିବା ପାଇଁ ଆପଣ ଚାହୁଁନଥିବା ଗୋପନୀୟ ସୂଚନା ଦୟାକରି ଦିଅନ୍ତୁ ନାହିଁ।</p><p>ଆପଣଙ୍କ ଭବିଷ୍ୟତର ବାର୍ତ୍ତାଳାପକୁ ଆମର ଜେନେରେଟିଭ AI ମଡେଲଗୁଡ଼ିକୁ ତାଲିମ ଦେବା ପାଇଁ ବ୍ୟବହାର କରାଯାଉ ବୋଲି ଯଦି ଆପଣ ଚାହୁଁନାହାଁନ୍ତି, ତେବେ ଆପଣ ଆପଣଙ୍କର Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ସେଟିଂସ</a>ରେ ଅପ୍ଟ ଆଉଟ କରିପାରିବେ। ଯଦି ଆପଣ ମତାମତ ପ୍ରଦାନ କରିବାକୁ ବାଛନ୍ତି, ତେବେ ଆପଣ ଅପ୍ଟ ଆଉଟ କରିଥିଲେ ମଧ୍ୟ Google ଆମର ଜେନେରେଟିଭ AI ମଡେଲଗୁଡ଼ିକୁ ତାଲିମ ଦେବା ପାଇଁ ସେହି ମତାମତ ଏବଂ ଯେ କୌଣସି ସମ୍ବନ୍ଧିତ ବିଷୟବସ୍ତୁ (ଉ.ଦା., ସମ୍ବନ୍ଧିତ ବାର୍ତ୍ତାଳାପ)କୁ ବ୍ୟବହାର କରିପାରିବ।</p>',settingsHeader:"AI ମଡେଲ ଟ୍ରେନିଂକୁ ଅନୁମତି ଦିଅନ୍ତୁ",settingsBody:'<p>Googleକୁ ଏହାର ଜେନେରେଟିଭ AI ମଡେଲଗୁଡ଼ିକୁ ତାଲିମ ଦେବା ପାଇଁ ଆପଣଙ୍କ ଭବିଷ୍ୟତର Stitch ବାର୍ତ୍ତାଳାପକୁ ବ୍ୟବହାର କରିବାକୁ ଦିଅନ୍ତୁ। ଆପଣ ପ୍ରଦାନ କରିବାକୁ ବାଛିଥିବା ଯେ କୌଣସି ମତାମତ ପାଇଁ ଅପ୍ଟ ଆଉଟ କରିବା ଲାଗୁ ହୁଏ ନାହିଁ। <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">ଅଧିକ ଜାଣନ୍ତୁ</a>।</p>'},cY={banner:'<p>Obowiązują <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Warunki usług Google</a> oraz <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Zasady użytkowania</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Informacje na temat ochrony prywatności</a> opisują, w jaki sposób korzystamy z Twoich danych. Twoje rozmowy i kod mogą być sprawdzane i wykorzystywane do ulepszania AI od Google. Dowiedz się, <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">jaki masz wybór</a>. Stitch może popełniać błędy, więc sprawdzaj wygenerowane odpowiedzi i <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">zachowaj ostrożność przy korzystaniu z kodu</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Ostatnia aktualizacja: 20 maja 2025 r.</p><p>Te informacje oraz nasza <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">polityka prywatności</a> opisują, w jaki sposób Stitch przetwarza Twoje dane. Przeczytaj je uważnie.</p><p>Gdy korzystasz z usługi Stitch, Google gromadzi Twoje rozmowy (w tym prompty i załączniki oraz wygenerowane wyniki), powiązane informacje o korzystaniu z funkcji, a także Twoje opinie. Zgodnie z naszą <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">polityką prywatności</a> używamy w Google tych danych, m.in. aby zapewniać, ulepszać i rozwijać nasze produkty, usługi oraz technologie uczenia maszynowego. W tych celach osoby weryfikujące treści (w tym przeszkoleni weryfikatorzy pracujący dla naszych dostawców usług) przeglądają niektóre rozmowy. Nie podawaj informacji poufnych, jeśli nie chcesz, żeby zobaczyła je osoba weryfikująca treści lub żeby zostały one użyte do ulepszania AI od Google.</p><p>Jeśli nie chcesz, aby Twoje przyszłe rozmowy były wykorzystywane do trenowania naszych modeli generatywnej AI, możesz z tego zrezygnować w <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ustawieniach</a> usługi Stitch. Jeśli zrezygnujesz z takiego wykorzystywania danych, ale zdecydujesz się przesłać opinię, Google nadal może użyć zawartych w niej informacji wraz ze wszelkimi powiązanymi treściami (np. związanymi z nią rozmowami) do trenowania modeli generatywnej AI.</p>',settingsHeader:"Zezwalaj na trenowanie modeli AI",settingsBody:'<p>Pozwól Google na używanie Twoich przyszłych rozmów w usłudze Stitch do trenowania modeli generatywnej AI. Rezygnacja nie dotyczy przesyłanych przez Ciebie opinii. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Więcej informacji</a></p>'},uY={banner:'<p>Se aplică <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Termenii Google</a> și <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Politica privind utilizarea</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Notificarea privind confidențialitatea</a> descrie modul în care îți sunt gestionate datele. Conversațiile și codul tău pot fi examinate și folosite pentru a îmbunătăți Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Află mai multe despre ce opțiuni ai</a>. Stitch poate face greșeli, așadar verifică încă o dată și <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">folosește codul cu precauție</a>.</p>',privacyHeader:"Notificarea privind confidențialitatea Stitch",privacyBody:'<p>Data ultimei actualizări: 20 mai 2025</p><p>Această notificare și <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Politica noastră de confidențialitate</a> descriu modul în care Stitch îți gestionează datele. Citește-le cu atenție.</p><p>Când folosești Stitch, Google îți colectează conversațiile (inclusiv solicitările, atașamentele și datele generate), informațiile asociate privind utilizarea funcției și feedbackul. Google folosește aceste date în conformitate cu <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Politica de confidențialitate</a>, inclusiv pentru a oferi, a îmbunătăți și a dezvolta produse și servicii Google și tehnologii de învățare automată. Evaluatorii umani (inclusiv examinatori pregătiți de la furnizorii noștri de servicii) examinează unele conversații în aceste scopuri. Nu introduce informații confidențiale pe care nu dorești să le vadă un examinator sau pe care nu dorești ca Google să le folosească pentru a îmbunătăți Google AI.</p><p>Dacă nu dorești ca viitoarele tale conversații să fie folosite pentru a ne instrui modelele de AI generativ, poți renunța din <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">setările</a> Stitch. Dacă alegi să trimiți feedback, Google poate folosi acest feedback și orice conținut asociat (de exemplu, conversații asociate) pentru a instrui modelele de AI generativ, chiar dacă ai renunțat.</p>',settingsHeader:"Permite instruirea modelului AI",settingsBody:'<p>Permite ca Google să-ți folosească viitoarele conversații cu Stitch pentru a instrui modelele Google de AI generativ. Renunțarea nu se aplică și feedbackului pe care alegi să-l trimiți. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Află mai multe</a>.</p>'},dY={banner:'<p>Действуют <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Условия использования Google</a> и <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Правила в отношении запрещенного использования генеративного ИИ</a>. В <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Примечании о конфиденциальности</a> рассказано, как обрабатываются ваши данные. Мы можем проверять и использовать ваши чаты и код, чтобы улучшать искусственный интеллект от Google. Узнайте больше <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">о доступных настройках</a>. Stitch может ошибаться. Обязательно проверяйте полученные ответы и <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">сгенерированный код</a>.</p>',privacyHeader:"Примечание о конфиденциальности для Stitch",privacyBody:'<p>Последнее обновление: 20 мая 2025 г.</p><p>В этом примечании и нашей <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Политике конфиденциальности</a> описано, как Stitch обрабатывает вашу информацию. Просим вас внимательно ознакомиться с ними.</p><p>Когда вы используете Stitch, Google собирает ваши чаты (включая запросы, прикрепленные файлы и сгенерированный контент), отзывы и сведения об использовании функций. Google использует эту информацию в соответствии с <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Политикой конфиденциальности</a>, в том числе чтобы предоставлять, улучшать и разрабатывать технологии машинного обучения, продукты и сервисы. Для этих целей обученные специалисты Google или наших поставщиков услуг могут проверять некоторые чаты. Не вводите в чатах конфиденциальную информацию, которую вы бы не хотели показывать специалисту или передавать Google для улучшения ИИ.</p><p>Чтобы будущие чаты не использовались для обучения моделей генеративного ИИ, отключите сбор этих сведений в <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">настройках</a> Stitch. Даже если вы это сделаете, Google сможет использовать ваши отзывы, связанные с ними чаты и другой контент для обучения своих моделей генеративного ИИ.</p>',settingsHeader:"Разрешить обучение ИИ-моделей",settingsBody:'<p>Google будет использовать будущие чаты со Stitch для обучения своих моделей генеративного ИИ. Отказ не распространяется на ваши отзывы. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Подробнее…</a></p>'},mY={banner:'<p>Platia <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">zmluvné podmienky</a> a <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">pravidlá používania spoločnosti Google</a>. V <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">oznámení o ochrane súkromia</a> je uvedené, ako zaobchádzame s vašimi údajmi. Vaše konverzácie a kód sa môžu kontrolovať a používať na zlepšovanie umelej inteligencie od spoločnosti Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Aké máte možnosti</a> Služba Stitch môže robiť chyby, preto si jej odpovede overujte a <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">kód používajte uvážlivo</a>.</p>',privacyHeader:"Oznámenie o ochrane súkromia v službe Stitch",privacyBody:'<p>Naposledy aktualizované: 20. mája 2025</p><p>Toto oznámenie a naše <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravidlá ochrany súkromia</a> opisujú, ako služba Stitch spracúva vaše údaje. Pozorne si ich prečítajte.</p><p>Keď používate službu Stitch, spoločnosť Google zhromažďuje vaše konverzácie (vrátane pokynov, príloh a vygenerovaného výstupu), informácie o používaní súvisiacich funkcií a vašu spätnú väzbu. Spoločnosť Google pomocou týchto údajov a v súlade so svojimi <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravidlami ochrany súkromia</a> poskytuje, zlepšuje a vyvíja svoje produkty, služby aj technológie strojového učenia. Niektoré konverzácie sú na tieto účely preverované kontrolórmi (vrátane vyškolených kontrolórov od našich poskytovateľov služieb). Nezadávajte dôverné informácie, ktoré podľa vás nemá kontrolór vidieť alebo pomocou ktorých nemá spoločnosť Google zlepšovať svoju umelú inteligenciu.</p><p>Ak nechcete, aby sa naše modely generatívnej umelej inteligencie zlepšovali pomocou vašich budúcich konverzácií, môžete sa odhlásiť v <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">nastaveniach</a> služby Stitch. Ak sa rozhodnete poskytnúť spätnú väzbu, spoločnosť Google môže pomocou nej aj akéhokoľvek pridruženého obsahu (napr. súvisiacich konverzácií) cvičiť svoje modely generatívnej umelej inteligencie aj vtedy, keď ste sa odhlásili.</p>',settingsHeader:"Povoľovať optimalizáciu modelov umelej inteligencie",settingsBody:'<p>Umožnite spoločnosti Google cvičiť svoje modely generatívnej umelej inteligencie pomocou vašich budúcich konverzácií v službe Stitch. Odhlásenie sa nevzťahuje na žiadnu spätnú väzbu, ktorú sa rozhodnete poskytnúť. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Ďalšie informácie</a></p>'},pY={banner:'<p>Veljajo <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googlovi pogoji</a> in <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">pravilnik o uporabi</a>. V <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">obvestilu o zasebnosti</a> je opisano, kako ravnamo z vašimi podatki. Vaši pogovori in koda bodo morda pregledani in uporabljeni za izboljšanje Googlove umetne inteligence. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Preberite več o svojih izbirah</a>. Stitch se lahko tudi zmoti, zato preverite odgovor in <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">kodo uporabljajte previdno</a>.</p>',privacyHeader:"Pravilnik o zasebnosti za Stitcha",privacyBody:'<p>Nazadnje posodobljeno: 20. maj 2025</p><p>V tem obvestilu in našem <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravilniku o zasebnosti</a> je opisano, kako Stitch obdeluje vaše podatke. Pazljivo jih preberite.</p><p>Ko uporabljate Stitcha, Google zbira vaše pogovore (vključno s pozivi, prilogami in generiranimi izhodnimi podatki), podatke o uporabi sorodnih funkcij in vaše povratne informacije. Google skladno s svojim <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">pravilnikom o zasebnosti</a> te podatke uporablja med drugim za zagotavljanje, izboljšanje in razvoj Googlovih izdelkov ter storitev in tehnologij strojnega učenja. Za te namene pregledovalci (vključno z usposobljenimi pregledovalci naših ponudnikov storitev) pregledajo nekatere pogovore. Ne vnašajte zaupnih podatkov, za katere ne želite, da bi jih pregledovalec videl ali Google uporabil za izboljšanje Googlove umetne inteligence.</p><p>Če ne želite, da se vaši prihodnji pogovori uporabljajo za usposabljanje modelov generativne umetne inteligence, lahko to onemogočite v Stitchevih <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">nastavitvah</a>. Če posredujete povratne informacije, lahko Google te povratne informacije in morebitno povezano vsebino (na primer povezane pogovore) uporabi za usposabljanje modelov generativne umetne inteligence, tudi če ste to onemogočili.</p>',settingsHeader:"Dovoli usposabljanje modelov umetne inteligence",settingsBody:'<p>Dovolite Googlu, da prihodnje pogovore s Stitchem uporablja za usposabljanje modelov generativne umetne inteligence. Onemogočenje ne velja za morebitne povratne informacije, ki jih posredujete. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Preberite več o tem</a>.</p>'},gY={banner:'<p>Примењују се <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google услови</a> и <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">смернице за коришћење</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Обавештење о приватности</a> описује како се поступа са подацима. Конверзације и кôд могу да се прегледају и користе за побољшање Google AI-ја. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Сазнајте више о доступним изборима</a>. Stitch може да прави грешке, па проверите резултате и <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">пажљиво користите кôд</a>.</p>',privacyHeader:"Обавештење о приватности за Stitch",privacyBody:'<p>Последње ажурирање: 20. мај 2025.</p><p>Ово обавештење и <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">политика приватности</a> описују како Stitch управља подацима. Пажљиво их прочитајте.</p><p>Када користите Stitch, Google прикупља конверзације (укључујући упите и прилоге, као и генерисане резултате), повезане информације о коришћењу функција и повратне информације. Google користи ове податке, у складу са <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">политиком приватности</a>, између осталог, да би пружао, побољшавао и развијао Google производе, услуге и технологије машинског учења. Особе које прегледају (укључујући обучене прегледаче добављача услуга) у те сврхе прегледају неке конверзације. Не уносите поверљиве информације за које не желите да их прегледач види нити да их Google користи за побољшање Google вештачке интелигенције.</p><p>Ако не желите да се будуће конверзације користе за обучавање модела генеративне вештачке интелигенције, можете то да онемогућите у Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">подешавањима</a>. Ако одаберете да пружате повратне информације, Google може да користи те повратне информације и сав повезани садржај (нпр. повезане конверзације) да би обучавао моделе генеративне вештачке интелигенције чак и ако сте то онемогућили.</p>',settingsHeader:"Дозволите обуку модела вештачке интелигенције",settingsBody:'<p>Дозволите Google-у да користи будуће Stitch конверзације за обуку модела генеративне вештачке интелигенције. Онемогућавање ове опције неће важити за евентуалне повратне информације које одаберете да пружите. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Сазнајте више</a>.</p>'},hY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Googles villkor</a> och<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">användarpolicy</a> gäller. I <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">integritetsmeddelandet</a> kan du läsa om hur din data behandlas. Dina konversationer och kod kan granskas och användas för att förbättra Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Läs mer om dina val</a>. Stitch kan göra misstag, så dubbelkolla den och <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">använd kod försiktigt</a>.</p>',privacyHeader:"Integritetsmeddelande för Stitch",privacyBody:'<p>Senast uppdaterad: 20 maj 2025</p><p>I det här meddelandet och vår <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">integritetspolicy</a> beskrivs hur din data hanteras i Stitch. Läs igenom dem noggrant.</p><p>När du använder Stitch samlar Google in dina konversationer (inklusive promptar och bilagor och genererad utdata) relaterad information om funktionsanvändning och din feedback. Google använder denna data i enlighet med vår <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">integritetspolicy</a>, inklusive för att tillhandahålla, förbättra och utveckla Googles produkter och tjänster samt maskininlärningsteknik. Mänskliga granskare (inklusive utbildade granskare från våra tjänsteleverantörer) granskar vissa konversationer i dessa syften. Ange inte konfidentiell information som du inte vill att en granskare ska se eller att Google ska använda för att förbättra Google AI.</p><p>Om du inte vill att dina framtida konversationer ska användas för att träna våra AI-modeller kan du välja bort detta i dina inställningar i Stitch . Om du väljer att lämna feedback kan Google använda den feedbacken och tillhörande innehåll (t.ex. relaterade konversationer) för att träna våra generativa AI-modeller även om du har valt att inte delta.</p>',settingsHeader:"Tillåt träning av AI-modell",settingsBody:'<p>Låt Google använda dina framtida Stitch-konversationer för att träna sina generativa AI-modeller. Även om du väljer bort detta gäller det inte för eventuell feedback som du lämnar. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Läs mer</a>.</p>'},fY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Masharti ya Google</a> pamoja na <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Sera ya Matumizi </a> vinatumika. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Ilani ya Faragha</a> inaelezea jinsi data yako inavyoshughulikiwa. Misimbo na mazungumzo yako yanaweza kuhakikiwa na kutumiwa kuboresha Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Pata maelezo kuhusu chaguo ulizonazo</a>. Stitch inaweza kukosea, kwa hivyo kagua na <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">utumie msimbo kwa uangalifu</a>.</p>',privacyHeader:"Ilani ya Faragha ya Stitch",privacyBody:'<p>Mara ya mwisho kusasishwa: Tarehe 20 Mei, 2025</p><p>Ilani hii pamoja na <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Sera yetu ya Faragha</a> inaelezea jinsi Stitch inavyoshughulikia data yako. Tafadhali zisome kwa makini.</p><p>Unapotumia Stitch, Google hukusanya mazungumzo yako (ikiwa ni pamoja na vidokezo na viambatisho na matokeo yaliyotayarishwa), maelezo yanayohusiana na matumizi ya kipengele pamoja na maoni yako. Google hutumia data hii, kulingana na <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Sera yetu ya Faragha</a>, kutoa, kuboresha na kubuni bidhaa, huduma pamoja na teknolojia za mashine kujifunza za Google. Wahakiki wanadamu (ikiwa ni pamoja na wahakiki waliohitimu kutoka kwa watoa huduma wetu) hukagua baadhi ya mazungumzo kwa madhumuni haya. Tafadhali usiweke taarifa za siri ambazo hungependa mhakiki aone au Google itumie kuboresha Google AI.</p><p>Iwapo hungependa mazungumzo yako ya siku zijazo yatumiwe kufunza mifumo yetu ya AI zalishi, unaweza kujiondoa kwenye <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">mipangilio</a> yako ya Stitch. Ukichagua kutoa maoni, Google inaweza kutumia maoni hayo na maudhui yoyote yanayohusiana (k.m., mazungumzo yanayohusiana) kufunza mifumo yetu ya AI zalishi hata ikiwa umejiondoa.</p>',settingsHeader:"Ruhusu Mafunzo ya Mfumo wa AI",settingsBody:'<p>Ruhusu Google itumie mazungumzo yako ya siku zijazo na Stitch kufunza mifumo yake ya AI zalishi. Kujiondoa hakuathiri maoni yoyote unayotoa. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Pata maelezo zaidi</a>.</p>'},AY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google விதிமுறைகள்</a> மற்றும் <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">பயன்பாடு தொடர்பான கொள்கை</a> பொருந்தும். உங்கள் தரவு எப்படிக் கையாளப்படுகிறது என்பதைத் <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">தனியுரிமை அறிக்கை</a> விவரிக்கிறது. உங்கள் உரையாடல்களும் குறியீடும் மதிப்பாய்வு செய்யப்பட்டு Google AIயை மேம்படுத்த பயன்படுத்தப்படக்கூடும். <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">உங்கள் விருப்பங்கள் குறித்துத் தெரிந்துகொள்ளுங்கள்</a>. Stitch கருவி தவறுகள் செய்யலாம் என்பதால் அதைச் சரிபார்த்துக் கொள்ளுங்கள். <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">குறியீட்டைக் கவனமாகப் பயன்படுத்துங்கள்</a>.</p>',privacyHeader:"Stitch தனியுரிமை அறிக்கை",privacyBody:'<p>கடைசியாகப் புதுப்பித்தது: மே 20, 2025</p><p>இந்த அறிவிப்பும் எங்கள் <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">தனியுரிமைக் கொள்கையும்</a> Stitch உங்கள் தரவைக் கையாளும் விதத்தை விவரிக்கின்றன. இவற்றைக் கவனமாகப் படியுங்கள்.</p><p>நீங்கள் Stitch கருவியைப் பயன்படுத்தும்போது, உங்கள் உரையாடல்கள் (ப்ராம்ப்ட்டுகள், இணைப்புகள், உருவாக்கப்பட்ட வெளியீடு உட்பட), தொடர்புடைய அம்சத்தின் பயன்பாடு குறித்த தகவல்கள், உங்கள் கருத்து ஆகியவற்றை Google சேகரிக்கும். Google தயாரிப்புகள் மற்றும் சேவைகள், மெஷின் லேர்னிங் தொழில்நுட்பங்கள் ஆகியவற்றை வழங்குதல், மேம்படுத்துதல், உருவாக்குதல் உட்பட எங்கள் <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">தனியுரிமைக் கொள்கையுடன்</a> இணங்கும் விதத்தில் Google இந்தத் தரவைப் பயன்படுத்தும். இந்த நோக்கங்களுக்காக மதிப்பாய்வாளர்கள் (எங்கள் சேவை வழங்குநர்களிடம் உள்ள மதிப்பாய்வாளர்கள் உட்பட) சில உரையாடல்களை மதிப்பாய்வு செய்வார்கள். மதிப்பாய்வாளர் பார்க்கக்கூடாது அல்லது Google AIயை மேம்படுத்த Google பயன்படுத்தக்கூடாது என்று நீங்கள் விரும்பும் ரகசியமான தகவல்களை டைப் செய்யாதீர்கள்.</p><p>எங்களின் ஜெனரேட்டிவ் AI மாடல்களுக்குப் பயிற்சியளிக்க உங்கள் எதிர்கால உரையாடல்களைப் பயன்படுத்த வேண்டாம் என நீங்கள் கருதினால், Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">அமைப்புகளில்</a> ஒப்புதல் நீக்கலாம். நீங்கள் கருத்து வழங்குவதற்குத் தேர்வுசெய்தால், ஒப்புதல் நீக்கியிருந்தாலும் எங்கள் ஜெனரேட்டிவ் AI மாடல்களுக்குப் பயிற்சியளிக்க, அந்தக் கருத்தையும் தொடர்புடைய உள்ளடக்கத்தையும் Google பயன்படுத்தலாம் (எ.கா. தொடர்புடைய உரையாடல்கள்).</p>',settingsHeader:"AI மாடல் பயிற்சியை அனுமதித்தல்",settingsBody:'<p>Google அதன் ஜெனரேட்டிவ் AI மாடல்களுக்குப் பயிற்சியளிக்க உங்கள் எதிர்கால Stitch உரையாடல்களைப் பயன்படுத்த அனுமதியுங்கள். ஒப்புதல் நீக்குவது நீங்கள் வழங்குவதற்குத் தேர்வுசெய்யும் எந்தக் கருத்திற்கும் பொருந்தாது. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">மேலும் அறிக</a>.</p>'},EY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google నియమాలు</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">, వినియోగ పాలసీ</a>వర్తిస్తాయి. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">గోప్యతా ప్రకటన</a> అనేది మీ డేటాను ఎలా హ్యాండిల్ చేస్తారో వివరిస్తుంది. మీ సంభాషణలను, కోడ్​ను Google AIని మెరుగుపరచడానికి ఉపయోగించే అవకాశం ఉంది. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">మీ ఎంపికల గురించి తెలుసుకోండి</a>. Stitch తప్పులు చేయవచ్చు, కాబట్టి దాన్ని ఒకటికి రెండుసార్లు డబుల్-చెక్ చేసి <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">కోడ్‌ను జాగ్రత్తగా ఉపయోగించండి</a>.</p>',privacyHeader:"Stitch గోప్యతా ప్రకటన",privacyBody:'<p>చివరిగా అప్‌డేట్ చేసిన తేదీ: మే 20, 2025</p><p>మీ డేటాను Stitch ఎలా హ్యాండిల్ చేస్తుందో ఈ నోటీసు, మా <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">గోప్యతా పాలసీ</a> వివరిస్తాయి. దయచేసి వాటిని జాగ్రత్తగా చదవండి.</p><p>మీరు Stitchను ఉపయోగించినప్పుడు, Google మీ సంభాషణలను (ప్రాంప్ట్‌లు, అటాచ్‌మెంట్‌లు, అలాగే జెనరేట్ చేసిన అవుట్‌పుట్‌తో సహా), సంబంధిత ఫీచర్ వినియోగ సమాచారాన్ని, మీ ఫీడ్‌బ్యాక్‌ను సేకరిస్తుంది. Google ప్రోడక్ట్‌లను, సర్వీస్‌లను, మెషిన్ లెర్నింగ్ టెక్నాలజీలను అందించడానికి, మెరుగుపరచడానికి, డెవలప్ చేయడానికి, మా <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">గోప్యతా పాలసీ</a>కి అనుగుణంగా, Google ఈ డేటాను ఉపయోగిస్తుంది. ఈ ప్రయోజనాల కోసం రివ్యూవర్‌లు (మా సర్వీస్ ప్రొవైడర్‌లకు చెందిన ట్రెయినింగ్ పొందిన రివ్యూవర్‌లతో సహా) కొన్ని సంభాషణలను రివ్యూ చేస్తారు. రివ్యూవర్ చూడకూడదని లేదా Googleకు చెందిన AI టెక్నాలజీలను మెరుగుపరచడానికి Google ఉపయోగించకూడదని మీరు కోరుకునే గోప్యమైన సమాచారాన్ని దయచేసి ఎంటర్ చేయవద్దు.</p><p>మీ భవిష్యత్ సంభాషణలను మా జెనరేటివ్ AI మోడళ్లకు ట్రెయినింగ్ ఇవ్వడానికి ఉపయోగించకూడదు అని అనుకుంటే, మీరు Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">సెట్టింగ్‌ల</a>లో సమ్మతిని నిలిపివేయవచ్చు. మీరు ఫీడ్‌బ్యాక్‌ను అందించడాన్ని ఎంచుకుంటే, మీరు సమ్మతి నిలిపివేసినప్పటికీ, మా జెనరేటివ్ AI మోడళ్లకు ట్రెయినింగ్ ఇవ్వడానికి Google ఆ ఫీడ్‌బ్యాక్‌ను, దానికి సంబంధించి ఏదైనా అనుబంధ కంటెంట్‌ను (ఉదా., సంబంధిత సంభాషణలు) ఉపయోగించే అవకాశం ఉంటుంది.</p>',settingsHeader:"AI మోడల్ ట్రెయినింగ్‌ను అనుమతించండి",settingsBody:`<p>Google దాని జెనరేటివ్ AI మోడళ్లకు ట్రెయినింగ్ ఇవ్వడానికి మీ భవిష్యత్ Stitch సంభాషణలను ఉపయోగించడానికి అనుమతి ఇవ్వండి. మీరు 'సమ్మతిని నిలిపివేయండి'ని ఎంచుకున్నప్పటికీ, మీరు అందించే ఏదైనా ఫీడ్‌బ్యాక్ విషయంలో అది వర్తించదు. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">మరింత తెలుసుకోండి</a>.</p>`},vY={banner:'<p>เป็นไปตาม<a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">ข้อกำหนดของ Google</a> และ<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">นโยบายการใช้งาน</a> อ่านวิธีที่เราจัดการข้อมูลของคุณได้ที่<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">ประกาศเกี่ยวกับนโยบายความเป็นส่วนตัว</a> ระบบอาจตรวจสอบและใช้บทสนทนาและโค้ดของคุณเพื่อพัฒนา AI ของ Google <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ดูข้อมูลเกี่ยวกับตัวเลือกของคุณ</a> Stitch อาจทำผิดพลาดได้ ดังนั้นโปรดตรวจสอบคำตอบอีกครั้ง รวมถึง<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ใช้โค้ดอย่างระมัดระวัง</a></p>',privacyHeader:"ประกาศเกี่ยวกับนโยบายความเป็นส่วนตัวของ Stitch",privacyBody:'<p>ปรับปรุงล่าสุด: 20 พฤษภาคม 2025</p><p>ประกาศฉบับนี้และ<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">นโยบายความเป็นส่วนตัว</a>อธิบายวิธีที่ Stitch จัดการข้อมูลของคุณ โปรดอ่านอย่างละเอียด</p><p>เมื่อคุณใช้ Stitch ทาง Google จะเก็บรวบรวมบทสนทนา (รวมถึงพรอมต์ ไฟล์แนบ และเอาต์พุตที่สร้างขึ้น) ข้อมูลการใช้งานฟีเจอร์ที่เกี่ยวข้อง ตลอดจนความคิดเห็นของคุณ Google ใช้ข้อมูลนี้โดยเป็นไปตาม<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">นโยบายความเป็นส่วนตัว</a> และใช้เพื่อจัดหา ปรับปรุง และพัฒนาผลิตภัณฑ์ บริการ รวมถึงเทคโนโลยีแมชชีนเลิร์นนิงของ Google เจ้าหน้าที่ตรวจสอบ (รวมถึงผู้ตรวจสอบที่ผ่านการฝึกอบรมจากผู้ให้บริการของเรา) จะตรวจสอบบทสนทนาบางส่วนเพื่อวัตถุประสงค์เหล่านี้ โปรดอย่าป้อนข้อมูลลับที่คุณไม่ต้องการให้ผู้ตรวจสอบเห็นหรือให้ Google ใช้เพื่อพัฒนา AI ของ Google</p><p>หากคุณไม่ต้องการให้เรานำบทสนทนาในอนาคตไปใช้ฝึกโมเดล Generative AI คุณสามารถเลือกไม่อนุญาตให้ใช้ข้อมูลได้ใน<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">การตั้งค่า</a> Stitch หากคุณเลือกที่จะแสดงความคิดเห็น Google สามารถใช้ความคิดเห็นนั้นและเนื้อหาที่เกี่ยวข้อง (เช่น บทสนทนาที่เกี่ยวข้อง) เพื่อฝึกโมเดล Generative AI แม้ว่าคุณจะเลือกไม่อนุญาตให้ใช้ข้อมูลไว้ก็ตาม</p>',settingsHeader:"อนุญาตให้ฝึกโมเดล AI",settingsBody:'<p>ให้ Google ใช้บทสนทนาในอนาคตกับ Stitch เพื่อฝึกโมเดล Generative AI การเลือกไม่อนุญาตให้ใช้ข้อมูลไม่มีผลกับความคิดเห็นที่คุณอาจต้องการเสนอแนะ <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">ดูข้อมูลเพิ่มเติม</a></p>'},MY={banner:`<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google Şartları</a> ve <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Kullanım Politikası</a> geçerlidir. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Gizlilik Uyarısı</a>'nda verilerinizin nasıl kullanıldığı açıklanır. Sohbetleriniz ile kodlarınız incelenebilir ve Google'ın Yapay Zekası'nı daha iyi hale getirmek için kullanılabilir. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Seçenekleriniz hakkında bilgi edinin</a>. Stitch hata yapabileceğinden verdiği yanıtları doğrulayın ve <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">kodları dikkatli kullanın</a>.</p>`,privacyHeader:"Stitch Privacy Notice",privacyBody:`<p>Son güncelleme: 20 Mayıs 2025</p><p>Bu uyarı ve <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Gizlilik Politikamızda</a> Stitch'in verilerinizi nasıl işlediği açıklanmaktadır. Lütfen bu belgeleri dikkatlice okuyun.</p><p>Stitch'i kullandığınızda sohbetleriniz (istemler, ekler ve üretilen çıktılar dahil), ilgili özellik kullanımı bilgileriniz ve geri bildirimleriniz Google tarafından toplanır. Google; ürünlerini, hizmetlerini ve makine öğrenimi teknolojilerini sunmak, daha iyi hale getirmek ve geliştirmek için bu verileri <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Gizlilik Politikamıza</a> uygun şekilde kullanır. İnceleme uzmanları (servis sağlayıcılarımızın eğitimli inceleme uzmanları dahil) bu amaçlar doğrultusunda bazı sohbetleri inceler. Lütfen inceleme uzmanlarının görmesini veya Google'ın Yapay Zekası'nı geliştirmek için Google tarafından kullanılmasını istemediğiniz gizli bilgileri girmeyin.</p><p>Gelecekteki sohbetlerinizin üretken yapay zeka modellerimizi eğitmek için kullanılmasını istemiyorsanız Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ayarlarınızdan</a> bu seçeneği devre dışı bırakabilirsiniz. Geri bildirim vermeyi tercih ederseniz, seçeneği devre dışı bırakmış olsanız bile bu geri bildirim ve tüm ilişkili içerikler (ör. alakalı sohbetler veya kodlar) üretken yapay zeka modellerimizi eğitmek için Google tarafından kullanılabilir.</p>`,settingsHeader:"Yapay Zeka Modelinin Eğitilmesine İzin Ver",settingsBody:`<p>Google'ın, üretken yapay zeka modellerini eğitmek için gelecekteki Stitch sohbetlerinizi kullanmasına izin verin. Bu seçeneği devre dışı bırakmanız, vereceğiniz geri bildirimleri etkilemez. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Daha fazla bilgi edinin</a>.</p>`},SY={banner:'<p>Застосовуються <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Загальні положення й умови Google</a> і <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Правила щодо використання</a>. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Примітка про конфіденційність</a> містить інформацію щодо того, як обробляються ваші дані. Наші спеціалісти можуть переглядати ваші розмови й код, а також використовувати їх для покращення ШІ від Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Дізнайтеся про варіанти, які можна вибрати.</a> Stitch може помилятися, тож перевіряйте відповіді й <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">використовуйте код обачно</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Останнє оновлення: 20 травня 2025 року</p><p>У цьому сповіщенні й нашій <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Політиці конфіденційності</a> описано, як Stitch обробляє ваші дані. Уважно прочитайте цю інформацію.</p><p>Коли ви використовуєте Stitch, Google збирає ваші розмови (зокрема запити, вкладені файли й згенеровані результати), пов’язану інформацію про використання функцій і відгуки. Ми використовуємо ці дані відповідно до нашої <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Політики конфіденційності</a>, щоб надавати, покращувати й розвивати продукти, сервіси та технології машинного навчання Google. Для цих цілей спеціалісти (зокрема постачальники послуг, з якими співпрацює Google) переглядають деякі розмови. Не вказуйте конфіденційну інформацію, яку спеціалісти не мають бачити або використовувати для покращення ШІ від Google.</p><p>Якщо ви не хочете, щоб ваші майбутні розмови використовувалися для навчання моделей генеративного ШІ, можете вимкнути цей параметр у <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">налаштуваннях</a> Stitch. Якщо ви вирішите написати відгук, Google може використати його й інший контент (наприклад, пов’язані розмови) для навчання наших моделей генеративного ШІ, навіть якщо це налаштування вимкнено.</p>',settingsHeader:"Дозволити навчання моделей штучного інтелекту",settingsBody:'<p>Дозвольте Google використовувати ваші майбутні розмови зі Stitch для навчання моделей генеративного ШІ. Якщо ви вимкнете це налаштування, ми все одно використовуватимемо відгуки, які ви надаєте. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Докладніше.</a></p>'},yY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">‫</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">کی</a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">شرائط</a> اور <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">استعمال</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">کی</a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">پالیسی</a>لاگو ہوتی ہیں۔ <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">رازداری</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">کا</a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">نوٹس</a> اس بات کی وضاحت کرتا ہے کہ آپ کا ڈیٹا کس طرح ہینڈل کیا جاتا ہے۔ آپ کی گفتگوؤں اور کوڈ کا جائزہ لیا جا سکتا ہے اور Google AI کو بہتر بنانے کے لیے استعمال کیا جا سکتا ہے۔ <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">اپنے</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">انتخابات</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">کے</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">بارے</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">میں</a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">جانیں</a>۔ ‫Stitch سے غلطیاں ہو سکتی ہیں، اس لیے اسے دوبارہ چیک کریں اور <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">احتیاط</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کے</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">ساتھ</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کوڈ</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کا</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">استعمال</a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer"> </a><a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">کریں</a>۔</p>',privacyHeader:"‫Stitch کی رازداری کا نوٹس",privacyBody:'<p>آخری بار اپ ڈیٹ کیا گيا: 20 مئی 2025</p><p>یہ نوٹس اور ہماری <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">رازداری</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">کی</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">پالیسی</a> بیان کرتی ہے کہ Stitch آپ کے ڈیٹا کو کیسے ہینڈل کرتا ہے۔ براہ کرم انہیں بغور پڑھیں۔</p><p>جب آپ Stitch کا استعمال کرتے ہیں تو Google آپ کی گفتگوئیں (بشمول پرامپٹس اور منسلکات اور تخلیق کردہ آؤٹ پٹ)، متعلقہ خصوصیت کے استعمال کی معلومات اور آپ کے تاثرات کو جمع کرتا ہے۔ ‫Google اس ڈیٹا کا استعمال ہماری <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">رازداری</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">کی</a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"> </a><a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">پالیسی</a> کے مطابق کرتا ہے، بشمول Google پروڈکٹس اور سروسز اور مشین لرننگ ٹیکنالوجیز کو فراہم کرنے، انہیں بہتر بنانے اور انہیں تیار کرنے کے۔ ان مقاصد کے لیے کچھ گفتگوؤں کا جائزہ انسان جائزہ کاران (بشمول ہمارے سروس فراہم کنندگان کے تربیت یافتہ تجزیہ کار) لیتے ہیں۔ براہِ کرم ایسی کوئی رازدارانہ معلومات درج نہ کریں جنھیں آپ نہیں چاہتے کہ کوئی جائزہ کار دیکھے یا Google انہیں اپنی Google AI کو بہتر بنانے کے لیے استعمال کرے۔</p><p>اگر آپ نہیں چاہتے کہ آپ کی مستقبل کی گفتگوؤں کو ہمارے تخلیق کر سکنے والے AI ماڈلز کی تربیت کے لیے استعمال کیا جائے تو آپ اپنی Stitch کی <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">ترتیبات</a> میں جا کر آپٹ آؤٹ کر سکتے ہیں۔ اگر آپ تاثرات دینے کا انتخاب کرتے ہیں تو Google ان تاثرات اور ان سے منسلک کسی بھی مواد (جیسے، متعلقہ گفتگوئیں) کو ہمارے تخلیق کر سکنے والے AI ماڈلز کی تربیت کے لیے استعمال کر سکتا ہے، چاہے آپ آپٹ آؤٹ کر چکے ہوں۔</p>',settingsHeader:"‫AI ماڈل ٹریننگ کی اجازت دیں",settingsBody:'<p>‫Google کو اجازت دیں کہ وہ اپنے تخلیق کر سکنے والے AI ماڈلز کی تربیت کے لیے آپ کی مستقبل کی Stitch گفتگوؤں کو استعمال کر سکے۔ آپٹ آؤٹ کرنے کا اطلاق ان تاثرات پر نہیں ہوتا جو آپ فراہم کرنے کا انتخاب کرتے ہیں۔ <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">مزید</a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer"> </a><a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">جانیں</a>۔</p>'},bY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Điều khoản của Google</a> và <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Chính sách sử dụng của Google</a> sẽ áp dụng. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Thông báo về quyền riêng tư</a> mô tả cách dữ liệu của bạn được xử lý. Chúng tôi có thể xem xét và sử dụng mã cũng như dữ liệu về các cuộc trò chuyện của bạn để cải thiện AI của Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Tìm hiểu về các lựa chọn của bạn</a>. Stitch có thể mắc lỗi nên hãy xác minh công cụ này và <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">thận trọng khi dùng mã</a>.</p>',privacyHeader:"Thông báo về quyền riêng tư của Stitch",privacyBody:'<p>Lần cập nhật gần đây nhất: Ngày 20 tháng 5 năm 2025</p><p>Thông báo này và <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Chính sách quyền riêng tư</a> của chúng tôi mô tả cách Stitch xử lý dữ liệu của bạn. Vui lòng đọc kỹ thông báo và chính sách nói trên.</p><p>Khi bạn sử dụng Stitch, Google sẽ thu thập dữ liệu về các cuộc trò chuyện (bao gồm cả câu lệnh, tệp đính kèm và nội dung tạo sinh), thông tin về việc sử dụng tính năng liên quan cũng như ý kiến phản hồi của bạn. Google sử dụng dữ liệu này theo <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Chính sách quyền riêng tư</a> của chúng tôi, kể cả nhằm cung cấp, cải thiện và phát triển các sản phẩm, dịch vụ cũng như công nghệ học máy của Google. Để phục vụ những mục đích nêu trên, nhân viên đánh giá (bao gồm cả nhân viên đánh giá đã qua đào tạo của các nhà cung cấp dịch vụ cho chúng tôi) sẽ xem xét một số cuộc trò chuyện. Vui lòng không nhập thông tin mật mà bạn không muốn nhân viên đánh giá xem hoặc không muốn Google sử dụng để cải thiện AI của Google.</p><p>Nếu không muốn chúng tôi sử dụng dữ liệu về các cuộc trò chuyện của bạn trong tương lai để huấn luyện mô hình AI tạo sinh, thì bạn có thể chọn không cho phép trong phần <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">cài đặt</a> Stitch. Nếu bạn chọn đưa ra ý kiến phản hồi, thì Google có thể sử dụng ý kiến phản hồi đó và mọi nội dung liên quan (ví dụ: cuộc trò chuyện liên quan) để huấn luyện mô hình AI tạo sinh của công ty ngay cả khi bạn chọn không cho phép.</p>',settingsHeader:"Cho phép huấn luyện mô hình AI",settingsBody:'<p>Cho phép Google sử dụng dữ liệu về các cuộc trò chuyện của bạn trên Stitch trong tương lai để huấn luyện mô hình AI tạo sinh của Google. Việc từ chối không áp dụng cho bất kỳ phản hồi nào bạn tự nguyện cung cấp. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Tìm hiểu thêm</a>.</p>'},TY={banner:'<p><a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Imigomo yeGoogle</a> kanye <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Nenqubomgomo Yokusebenzisa</a> ziyasebenza. <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Isaziso Sobumfihlo</a> sichaza indlela idatha yakho esingathwa ngayo. Izingxoxo nekhodi yakho zingase zibuyekezwe futhi zisetshenziselwe ukuthuthukisa i-AI yeGoogle. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Funda mayelana nokukhetha kwakho</a>. IStitch ingenza amaphutha, ngakho-ke yihlolisise futhi <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">usebenzise ikhodi ngokucophelela</a>.</p>',privacyHeader:"Isaziso Sobumfihlo seStitch",privacyBody:'<p>Kugcine Ukubuyekezwa: 20 Meyi 2025</p><p>Lesi saziso kanye <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Nenqubomgomo yethu Yobumfihlo</a> zichaza ukuthi iStitch iyiphatha kanjani idatha yakho. Uyacelwa ukuthi uzifunde ngokucophelela.</p><p>Lapho usebenzisa iStitch, iGoogle iqoqa izingxoxo zakho (kubandakanya iziqalisi nezinanyathiselwa kanye nomphumela okhiqiziwe), ulwazi lokusetshenziswa kwesakhi esihlobene, kanye nempendulo yakho. IGoogle isebenzisa le datha, kanye <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Nenqubomgomo Yobumfihlo</a> yethu, kubandakanya ukuhlinzeka, ukuthuthukisa, nokusungula imikhiqizo namasevisi eGoogle nobuchwepheshe bokufunda komshini. Ababuyekezi abangabantu (kuyabandakanya nababuyekezi abaqeqeshiwe abavela kubahlinzeki bethu besevisi) babuyekeza ezinye izingxoxo ngalezi zinhloso. Sicela ungafaki ulwazi oluyimfihlo ongeke uthande ukuthi umbuyekezi alubone noma iGoogle ilusebenzise ukuthuthukisa iGoogle AI.</p><p>Uma ungafuni izingxoxo zakho zesikhathi esizayo zisetshenziselwe ukuqeqesha uhlelo lwethu lwe-AI ekhiqizayo, ungakhetha ukuphuma <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">kumasethingi</a> akho eStich. Uma ukhetha ukunikeza impendulo, iGoogle ingasebenzisa leyo mpendulo kanye nanoma iyiphi ikhontenti ehlobene (isb., izingxoxo ezihlobene) ukuqeqesha kohlelo lwethu lwe-AI ekhiqizayo ngisho noma ukhetha ukuphuma.</p>',settingsHeader:"Vumela Ukuqeqeshwa Kwemodeli ye-AI",settingsBody:'<p>Vumela iGoogle isebenzise izingxoxo zakho zeStitch zesikhathi esizayo ukuze iqeqeshe uhlelo lwe-AI ekhiqizayo. Ukukhetha ukuphuma ohlwini akusebenzi kunoma iyiphi impendulo ongase ukhethe ukuyinikeza. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Funda kabanzi</a>.</p>'},gu={af:Iq,am:Hq,ar:Vq,as:Lq,bg:Oq,bn:Zq,ca:wq,cs:Cq,da:Gq,de:xq,el:Nq,"en-GB":{banner:'<p>The <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google Terms</a> and <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Use Policy</a> apply. The <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Notice</a> describes how your data is handled. Your conversations and code may be reviewed and used to improve Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Learn about your choices</a>. Stitch can make mistakes, so double-check it and <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">use code with caution</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:`<p>Last updated: 20 May 2025</p><p>This notice and our <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a> describe how Stitch handles your data. Please read them carefully.</p><p>When you use Stitch, Google collects your conversations (including prompts and attachments and generated output), related feature usage information and your feedback. Google uses this data, consistent with our <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including to provide, improve and develop Google products and services and machine-learning technologies. Human reviewers (including trained reviewers from our service providers) review some conversations for these purposes. Please don't enter confidential information that you wouldn't want a reviewer to see or Google to use to improve Google AI.</p><p>If you don't want your future conversations used to train our generative AI models, you can opt out in your Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">settings</a>. If you choose to provide feedback, Google can use that feedback and any associated content (e.g. related conversations) to train our generative AI models even if you've opted out.</p>`,settingsHeader:"Allow AI model training",settingsBody:'<p>Let Google use your future Stitch conversations to train its generative AI models. Opting out does not apply to any feedback that you may choose to provide. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Learn more</a>.</p>'},"en-IN":{banner:'<p>The <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google Terms</a> and <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Use Policy</a> apply. The <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Notice</a> describes how your data is handled. Your conversations and code may be reviewed and used to improve Google AI. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Learn about your choices</a>. Stitch can make mistakes, so double-check it and <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">use code with caution</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Last updated: 20 May, 2025</p><p>This notice and our <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a> describe how Stitch handles your data. Please read them carefully.</p><p>When you use Stitch, Google collects your conversations (including prompts and attachments and generated output), related feature usage information, and your feedback. Google uses this data consistent with our <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including to provide, improve, and develop Google products and services and machine learning technologies. Human reviewers (including trained reviewers from our service providers) review some conversations for these purposes. Please do not enter confidential information that you would not want a reviewer to see or Google to use to improve Google AI.</p><p>If you do not want your future conversations used to train our generative AI models, you can opt out in your Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">settings</a>. If you choose to provide feedback, Google can use that feedback and any associated content (e.g., related conversations) to train our generative AI models even if you’ve opted out.</p>',settingsHeader:"Allow AI Model Training",settingsBody:'<p>Let Google use your future Stitch conversations to train its generative AI models. Opting out does not apply to any feedback you may choose to provide. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Learn more</a>.</p>'},"es-419":{banner:'<p>Se aplican las <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Condiciones</a> y la <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Política de Uso de Google</a>. En el <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Aviso de Privacidad</a>, se describe cómo se manejan sus datos. Es posible que sus conversaciones y código se revisen y usen para mejorar la IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Obtenga más información sobre sus elecciones</a>. Stitch puede cometer errores, así que verifique y <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">use el código con precaución</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Última actualización: 20 de mayo de 2025</p><p>Este aviso y nuestra <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidad</a> describen cómo Stitch maneja sus datos. Lea esta información detenidamente.</p><p>Cuando utiliza Stitch, Google recopila sus conversaciones (incluyendo sus instrucciones y archivos adjuntos, y los resultados generados), información relacionada con el uso de la función y sus comentarios. Google usa estos datos, de conformidad con nuestra <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidad</a>, para, entre otros fines, proporcionar, mejorar y desarrollar productos y servicios de Google, y tecnologías de aprendizaje automático. Nuestros revisores humanos (entre quienes se incluyen revisores capacitados de nuestros proveedores de servicios) analizan algunas conversaciones para estos fines. No ingrese información confidencial que no quiera que un revisor vea o que Google use para mejorar la IA de Google.</p><p>Si no quiere que se utilicen sus conversaciones futuras para entrenar nuestros modelos de IA generativa, puede elegir no proporcionar sus datos para este fin en la <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">configuración</a> de Stitch. Si decide enviar comentarios, Google podrá utilizarlos, junto con cualquier contenido asociado (p. ej., conversaciones relacionadas), para entrenar sus modelos de IA generativa, incluso si rechazó la opción.</p>',settingsHeader:"Permita el entrenamiento de modelos de IA",settingsBody:'<p>Permita que Google utilice sus conversaciones futuras con Stitch para entrenar sus modelos de IA generativa. Si elige no proporcionar sus datos, esto no se aplica para los comentarios que decida enviar. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Obtenga más información</a>.</p>'},es:Rq,et:Dq,eu:kq,fa:Pq,fi:zq,"fr-CA":{banner:`<p>Les <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">conditions de Google</a> et la <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">politique d'utilisation interdite</a> s'appliquent. L'<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">avis de confidentialité</a> décrit la façon dont vos données sont traitées. Vos conversations et votre code peuvent être examinés et utilisés pour améliorer l'IA de Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Apprenez-en plus sur vos choix.</a> Stitch peut faire des erreurs, alors vérifiez-le bien et <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">utilisez le code avec prudence</a>.</p>`,privacyHeader:"Avis de confidentialité de Stitch",privacyBody:`<p>Dernière mise à jour : 20 mai 2025</p><p>Cet avis et notre <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">politique de confidentialité</a> décrivent comment Stitch traite vos données. Veuillez les lire attentivement.</p><p>Lorsque vous utilisez Stitch, Google recueille vos conversations (y compris les requêtes et les pièces jointes), les informations sur l'utilisation des fonctionnalités associées et vos commentaires. Google utilise ces données, conformément à sa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">politique de confidentialité</a>, notamment pour fournir, améliorer et développer ses produits et services ainsi que ses technologies d'apprentissage automatique. Des réviseurs humains (y compris des réviseurs qualifiés qui travaillent pour nos fournisseurs de services) examinent certaines conversations à ces fins. Veuillez ne pas entrer de renseignements confidentiels que vous ne souhaiteriez pas qu'un réviseur voie ni que Google utilise pour améliorer l'IA de Google.</p><p>Si vous ne souhaitez pas que vos conversations futures soient utilisées pour entraîner nos modèles d'IA générative, vous pouvez refuser qu'elles le soient dans vos <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">paramètres</a> Stitch. Si vous choisissez de fournir des commentaires, Google peut utiliser ces commentaires et tout contenu associé (p. ex. des conversations connexes) pour entraîner nos modèles d'IA générative, même si vous avez refusé que vos conversations soient utilisées.</p>`,settingsHeader:"Autoriser l'entraînement de modèles d'IA",settingsBody:`<p>Laissez Google utiliser vos futures conversations Stitch pour entraîner ses modèles d'IA générative. Votre refus ne s'applique pas aux commentaires que vous pouvez choisir de fournir. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Apprenez-en plus.</a></p>`},fr:Uq,ga:_q,gl:jq,gu:Fq,hi:Bq,hr:qq,hu:Yq,id:Kq,is:Qq,it:Xq,iw:Wq,ja:Jq,kn:$q,ko:eY,lt:tY,lv:aY,ml:nY,mr:rY,ms:oY,nl:iY,no:sY,or:lY,pl:cY,"pt-BR":{banner:'<p>Os <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Termos do Google</a> e a <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Política de Uso</a> são válidos. No <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Aviso de privacidade</a>, descrevemos como seus dados são gerenciados. Suas conversas e seus códigos podem ser analisados e usados para aprimorar a IA do Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Saiba mais sobre suas opções</a>. O Stitch pode cometer erros. Por isso, é importante checar as respostas e <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">usar os códigos com cautela</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Última atualização: 20 de maio de 2025</p><p>Este aviso e nossa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidade</a> descrevem como o Stitch trata seus dados. Leia com atenção.</p><p>Quando você usa o Stitch, o Google coleta suas conversas (incluindo comandos e anexos e respostas geradas), informações de uso de recursos relacionados e seu feedback. O Google usa esses dados de acordo com nossa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>, inclusive para oferecer, melhorar e desenvolver produtos e serviços do Google e tecnologias de aprendizado de máquina. Revisores humanos (incluindo aqueles que foram treinados por nossos provedores de serviços) leem algumas conversas para esses fins. Não insira informações confidenciais que você não quer que sejam analisadas pelos revisores ou usadas pelo Google para melhorar nossa IA.</p><p>Para impedir que suas conversas futuras sejam usadas no treinamento dos nossos modelos de IA generativa, desative essa opção nas <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">configurações</a> do Stitch. Se você enviar feedback, o Google poderá usar seus comentários e qualquer conteúdo associado (por exemplo, conversas relacionadas) para treinar nossos modelos de IA generativa. Isso ocorrerá mesmo que essa configuração tenha sido desativada.</p>',settingsHeader:"Permitir o treinamento de modelos de IA",settingsBody:'<p>Deixe o Google usar suas conversas futuras do Stitch para treinar os modelos de IA generativa. A desativação dessa opção não se aplica ao feedback que você envia. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Saiba mais.</a></p>'},"pt-PT":{banner:'<p>Aplicam-se os <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Termos de Utilização da Google</a> e a <a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">Política de Utilização</a>. O <a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">Aviso de Privacidade</a> descreve a forma como tratamos os seus dados. As suas conversas e código podem ser revistos e usados para melhorar a IA da Google. <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">Saiba mais sobre as suas opções</a>. O Stitch pode cometer erros, por isso, verifique e <a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">use o código com cuidado</a>.</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>Última atualização: 20 de maio de 2025</p><p>Este aviso e a nossa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidade</a> descrevem a forma como o Stitch trata os seus dados. Leia-os atentamente.</p><p>Quando usa o Stitch, a Google recolhe as suas conversas (incluindo comandos, anexos e resultados gerados), informações sobre a utilização de funcionalidades relacionadas e o seu feedback. A Google usa estes dados, em conformidade com a nossa <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>, para oferecer, melhorar e desenvolver produtos e serviços Google e tecnologias de aprendizagem automática. Os revisores humanos (incluindo revisores com formação dos nossos fornecedores de serviços) reveem algumas conversas para estes fins. Não introduza informações confidenciais que não queira que um revisor veja ou que a Google use para melhorar a IA da Google.</p><p>Se não quiser que as suas conversas futuras sejam usadas para preparar os nossos modelos de IA generativa, pode desativar esta opção nas <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">definições</a> do Stitch. Se optar por dar feedback, a Google pode usar esse feedback e qualquer conteúdo associado (por exemplo, conversas relacionadas) para preparar os nossos modelos de IA generativa, mesmo que tenha desativado a opção.</p>',settingsHeader:"Permitir preparação de modelos de IA",settingsBody:'<p>Permita que a Google use as suas futuras conversas do Stitch para preparar os respetivos modelos de IA generativa. A desativação da opção não se aplica ao feedback que possa dar. <a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">Saiba mais</a>.</p>'},ro:uY,ru:dY,sk:mY,sl:pY,sr:gY,sv:hY,sw:fY,ta:AY,te:EY,th:vY,tr:MY,uk:SY,ur:yY,vi:bY,"zh-CN":{banner:'<p>须遵守<a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">《Google 条款》</a>和<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">《使用政策》</a>。<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">《隐私权声明》</a>说明了 Google 会如何处理您的数据。您的对话内容和代码可能会经过审核，并用于改进 Google AI 技术。<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">了解您有哪些选择</a>。Stitch 可能会出错，请注意核查，并<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">谨慎使用代码</a>。</p>',privacyHeader:"Stitch Privacy Notice",privacyBody:'<p>最后更新时间：2025 年 5 月 20 日</p><p>本声明和 Google 的<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">《隐私权政策》</a>说明了 Stitch 会如何处理您的数据。请仔细阅读。</p><p>您使用 Stitch 时，Google 会收集您的对话内容（包括提示、附件以及生成的输出内容）、相关功能使用信息以及您的反馈。Google 会依照<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">《隐私权政策》</a>中的规定，利用这些数据提供、改进和开发 Google 产品、服务和机器学习技术。人工审核员（包括服务提供商的专职审核员）会根据这些目的审核部分对话内容。请勿输入您不希望被审核员查看或被 Google 用于改进 Google AI 技术的机密信息。</p><p>如果您不希望将您未来的对话内容用于训练我们的生成式 AI 模型，则可以在 Stitch 的<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">设置</a>中选择不提供数据。如果您选择提供反馈，那么即使您已选择不提供数据，Google 仍可以使用该反馈以及任何相关内容（例如，相关对话）来训练我们的生成式 AI 模型。</p>',settingsHeader:"允许用于训练 AI 模型",settingsBody:'<p>允许 Google 使用您未来的 Stitch 对话内容来训练其生成式 AI 模型。即使选择不提供数据，Google 还是可以使用您自愿提供的反馈。<a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">了解详情</a>。</p>'},"zh-HK":{banner:'<p>須遵守《<a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google 條款</a>》以及《<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">使用政策</a>》。《<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">私隱聲明</a>》說明 Google 處理資料的方式。我們可能會審核和使用你的對話和程式碼來改善 Google AI。<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">瞭解你的選項</a>。Stitch 可能會出錯，因此請複查其答覆並<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">謹慎使用程式碼</a>。</p>',privacyHeader:"Stitch 私隱聲明",privacyBody:'<p>上次更新日期：2025 年 5 月 20 日</p><p>此聲明及我們的《<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">私隱權政策</a>》說明 Stitch 處理資料的方式，因此請仔細閱讀內容。</p><p>在你使用 Stitch 時，Google 會收集你的對話 (包括提示和附件以及生成的輸出內容)、相關功能使用情況資料，以及你的意見。Google 會根據其《<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">私隱權政策</a>》使用此資料，以作提供、改善和開發 Google 產品和服務以及機器學習技術等用途。人手審查員 (包括服務供應商的受訓審查員) 將會基於以上目的審核部分對話。請勿輸入你不希望審查員看到或讓 Google 用來改善 Google AI 的機密資料。</p><p>如果你不想我們使用你未來的對話來訓練生成式 AI 模型，你可以在 Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">設定</a>中選擇不提供資料。即使你選擇不提供資料，如果你選擇提供意見，Google 仍會使用有關意見和任何有關聯的內容 (例如相關對話) 來訓練生成式 AI 模型。</p>',settingsHeader:"允許 AI 模型訓練",settingsBody:'<p>讓 Google 使用你未來的 Stitch 對話來訓練生成式 AI 模型。選擇不提供的資料不包括任何你可能選擇提供的意見。<a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">瞭解詳情</a>。</p>'},"zh-TW":{banner:'<p>適用於《<a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer">Google 條款</a>》和《<a href="https://policies.google.com/terms/generative-ai/use-policy" target="_blank" rel="noopener noreferrer">使用政策</a>》。《<a href="https://stitch.withgoogle.com/privacy" target="_blank" rel="noopener noreferrer">隱私權聲明</a>》說明我們如何處理您的資料。您的對話內容和程式碼可能會經過審查，並用於改良 Google AI。<a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">進一步瞭解您的選項</a>。Stitch 可能會出錯，因此請查證回覆內容，<a href="https://g.co/legal/generative-code" target="_blank" rel="noopener noreferrer">並謹慎使用程式碼</a>。</p>',privacyHeader:"Stitch 隱私權聲明",privacyBody:'<p>上次更新日期：2025 年 5 月 20 日</p><p>本聲明和我們的《<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">隱私權政策</a>》說明 Stitch 如何處理您的資料，敬請詳閱。</p><p>使用 Stitch 時，Google 會蒐集對話內容 (包括提示、附件和生成的輸出內容)、相關功能使用資訊和意見回饋。Google 會根據《<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">隱私權政策</a>》使用這些資料，提供、強化及開發自家產品、服務和機器學習技術。人工審查員 (包括服務供應商端受過專業訓練的審查員) 會根據上述目的審查部分對話內容。請勿輸入機密資訊，這些資料可能會由審查員查看，或供 Google 改良 Google AI。</p><p>如果不希望我們使用您未來的對話內容訓練生成式 AI 模型，可以在 Stitch <a href="https://stitch.withgoogle.com/settings" target="_blank" rel="noopener noreferrer">設定</a>中選擇不提供資料。如果您選擇傳送意見回饋，Google 可以使用該意見及相關內容 (例如關聯的對話) 來訓練生成式 AI 模型 (即使您已設定不提供資料)。</p>',settingsHeader:"允許用於訓練 AI 模型",settingsBody:'<p>允許 Google 使用您未來在 Stitch 輸入的對話內容，訓練生成式 AI 模型。請注意，即使設定不提供資料，在您選擇傳送意見回饋時，這個設定並不適用。<a href="https://stitch.withgoogle.com/legal" target="_blank" rel="noopener noreferrer">瞭解詳情</a>。</p>'},zu:TY},j0e=()=>{const{userLanguageCode:e}=ct();let a=gu[e];if(!a&&e){if(e.startsWith("en"))return;const o=e.split("-")[0].toLowerCase(),i=Object.keys(gu).find(l=>l.startsWith(o));i?(console.warn(`Found matching locale strings ${i} for ${e}`),a=gu[i]):console.error(`No matching locale strings for ${e}`)}return a},VS=()=>{const{userLanguageCode:e}=ct();return e?e.startsWith("ar")||e.startsWith("fa")||e.startsWith("iw")||e.startsWith("ur"):!1},LS=t.memo(({size:e})=>{const{userIsLoggedIn:a,userVisibleName:o,login:i,chooseAccount:l,logout:u,userEmail:d}=ct(),m=VS(),{messages:g}=Be();retur